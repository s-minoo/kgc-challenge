<http://data.europa.eu/a4g/resource/id_671cfb3c-1ca2-4d4b-835e-015ca35ad0c4-01_AwardCriterionPrice_034a0028b7766b9205151778b1442c38> a ns1:AwardCriterion ;
    ns1:hasAwardCriterionType <http://publications.europa.eu/resource/authority/award-criterion-type/price> ;
    ns1:hasWeightValueType <http://publications.europa.eu/resource/authority/number-weight/poi-exa> ;
