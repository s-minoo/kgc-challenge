<http://data.europa.eu/a4g/resource/id_93da7e57-1661-4b17-915f-f7e45ee2e7c4-01_AwardCriterionQuality_05d463aa3e1e0e434e9af9124c4cd3dc3> a ns1:AwardCriterion ;
