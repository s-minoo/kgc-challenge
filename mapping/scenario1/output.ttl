    ns1:hasAdditionalInformation "Wartość zamówienia podstawowego: 4 881 386,99 zł; Wartość usług podobnych: 2 440 693,50 zł; Wartość usług objętych przedmiotem opcji: 1 464 416,10 zł"@pol ;
    ns1:hasDescription "Przedmiotem zamówienia są usługi z zakresu gospodarki leśnej obejmujące prace z zakresu hodowli i ochrony lasu, ochrony przeciwpożarowej, pozyskania i zrywki drewna oraz zagospodarowania turystycznego, gospodarki łąkowo-rolnej, gospodarki łowieckiej, nasiennictwa i selekcji, a także prac z zakresu zadrzewień, ubocznego użytkowania lasu oraz utrzymania dróg leśnych, dojazdów pożarowych i urządzeń wodno – melioracyjnych, do wykonania na terenie Nadleśnictwa Sarbia w latach 2026-2027 -  Leśnictwa Drzązgowo, Nówki, Gospodarka Łowiecka i łąkowo-Rolna na terenie OHZ LP Sarbia"@pol ;
    ns1:hasEstimatedValue <http://data.europa.eu/a4g/resource/id_0524b050-3597-4f62-b884-7e7fa869d522-01_LotMainMonetaryValue_78f186d4e5421cbb98772bb9b60414bd> ;
    ns1:hasID <http://data.europa.eu/a4g/resource/id_0524b050-3597-4f62-b884-7e7fa869d522-01_LotIdentifier_04b38b1436de31114ed1d8aaaf6a4321> ;
    ns1:hasPurpose <http://data.europa.eu/a4g/resource/id_0524b050-3597-4f62-b884-7e7fa869d522-01_LotPurpose_879a25f44af43b22ea267acea5a06734> ;
    ns1:hasTitle "Pakiet III - Leśnictwa Drzązgowo, Nówki, Gospodarka Łowiecka i łąkowo-Rolna na terenie OHZ LP Sarbia"@pol ;
    ns1:isSMESuitable true ;
