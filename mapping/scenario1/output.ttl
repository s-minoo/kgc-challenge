<http://data.europa.eu/a4g/resource/id_a07d0944-e38d-4550-a27b-01b8afc3d24a-01_Procedure> a ns1:Procedure ;
    ns1:foreseesContractSpecificTerm <http://data.europa.eu/a4g/resource/id_a07d0944-e38d-4550-a27b-01b8afc3d24a-01_ContractTermProcedure_511f7f3bfef642090c98513be278d78e> ;
    ns1:hasDescription "Предметът на обществената поръчката е извършване на извънгаранционно пълно сервизно и техническо обслужване, включително извършване на профилактика, диагностика, ремонт, доставка и монтаж на резервни части и консумативи, смяна на гуми, външно и вътрешно почистване, както и извършване на годишен технически преглед на служебните автомобили, предоставени за ползване от РДСП - Ловеч и на ДСП на територията на област Ловеч."@bul ;
    ns1:hasEstimatedValue <http://data.europa.eu/a4g/resource/id_a07d0944-e38d-4550-a27b-01b8afc3d24a-01_ProcedureMonetaryValue_0284f5beadb42f2651ff42b01ef108be> ;
