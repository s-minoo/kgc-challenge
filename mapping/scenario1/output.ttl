    ns1:hasID <http://data.europa.eu/a4g/resource/id_dd4ca65c-1d8b-412c-a4f2-150c5b2852ea-01_ProcurementDocumentIdentifier_26c559127d83adc082ca4d4fca3e5b68> ;
