<http://data.europa.eu/a4g/resource/id_2021-S-002-002911_OpeningTermLocation_e8c75fec73c755cd18b3bbb9cb1e6073> a ns2:Address ;
    ns2:fullAddress "Οι προσφορές υποβάλλονται ηλεκτρονικά, μέσω της διαδικτυακής πύλης www.promitheus.gov.gr του Ε.Σ.Η.ΔΗ.Σ., μέχρι την καταληκτική ημερομηνία και ώρα που ορίζεται ανωτέρω, σε ηλεκτρονικό φάκελο του υποσυστήματος. Για τη συμμετοχή, οι ενδιαφερόμενοι οικονομικοί φορείς απαιτείται να διαθέτουν ψηφιακή υπογραφή και να εγγραφούν στο ηλεκτρονικό σύστημα (Ε.Σ.Η.ΔΗ.Σ. - διαδικτυακή πύλη www.promitheus.gov.gr)."@el .

<http://data.europa.eu/a4g/resource/id_2021-S-002-002911_OpeningTerm_07ed3e37af1e5945b85ec7d6fc09c0c8> a ns1:LotSpecificTerm,
        ns1:OpeningTerm ;
    ns1:definesOpeningPlace <http://data.europa.eu/a4g/resource/id_2021-S-002-002911_OpeningTermLocation_e8c75fec73c755cd18b3bbb9cb1e6073> ;
    ns1:hasOpeningDateTime "2021-03-30T10:00:00"^^xsd:dateTime ;
    ns1:hasOpeningDescription "Η Ε.Δ. την ημερομηνία και ώρα που ορίζεται ανωτέρω, προβαίνει σε αποσφράγιση διαγωνισμού, έλεγχο δικαιολογητικών συμμετοχής, αξιολόγηση - βαθμολόγηση τεχνικών προσφορών, συντάσσει πρακτικό· το υποβάλλει προς έγκριση. Μετά, η Ε.Δ. προβαίνει στην αποσφράγιση οικονομικών προσφορών, αξιολόγηση - βαθμολόγησή τους, συντάσσει πρακτικό· το υποβάλλει προς έγκριση. Περισσότερα, άρθρα 4 και 5 οικείας διακήρυξης, και Ν.4412/16."@el .

