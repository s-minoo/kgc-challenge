    ns1:fulfillsStrategicProcurement <http://data.europa.eu/a4g/resource/id_a07d0944-e38d-4550-a27b-01b8afc3d24a-01_StrategicProcurement_334c4a4c42fdb79d7ebc3e73b517e6f8> ;
    ns1:hasDescription "Предметът на обществената поръчката е извършване на извънгаранционно пълно сервизно и техническо обслужване, включително извършване на профилактика, диагностика, ремонт, доставка и монтаж на резервни части и консумативи, смяна на гуми, външно и вътрешно почистване, както и извършване на годишен технически преглед на служебните автомобили, предоставени за ползване от РДСП - Ловеч и на ДСП на територията на област Ловеч."@bul ;
    ns1:hasEstimatedValue <http://data.europa.eu/a4g/resource/id_a07d0944-e38d-4550-a27b-01b8afc3d24a-01_LotMainMonetaryValue_0284f5beadb42f2651ff42b01ef108be> ;
    ns1:hasID <http://data.europa.eu/a4g/resource/id_a07d0944-e38d-4550-a27b-01b8afc3d24a-01_LotIdentifier_0658566dc8162546d4928a7f28560c4e> ;
    ns1:hasPurpose <http://data.europa.eu/a4g/resource/id_a07d0944-e38d-4550-a27b-01b8afc3d24a-01_LotPurpose_0f517a8ae2aaeef83963eed5718d4948> ;
    ns1:hasRecurrenceDescription "Предметът на настоящата обществена поръчка обуславя необходимост от повторяемост, за да бъде обезпечено сигурното и безопасно ползване на служебните автомобили, предоставени на РДСП - Ловеч и ДСП от област Ловеч, чрез пълно сервизно обслужване и ремонт."@bul ;
    ns1:hasTitle "„Осигуряване на извънгаранционно пълно сервизно обслужване и ремонт на служебните автомобили на АСП, предоставени за ползване на РДСП – Ловеч и на ДСП на територията на област Ловеч“"@bul ;
    ns1:isRecurrent true ;
    ns1:isSubjectToLotSpecificTerm <http://data.europa.eu/a4g/resource/id_a07d0944-e38d-4550-a27b-01b8afc3d24a-01_OpeningTerm_c123b6fdd1b401a8f8ce2cfecab64b16>,
        <http://data.europa.eu/a4g/resource/id_a07d0944-e38d-4550-a27b-01b8afc3d24a-01_SubmissionTermLot_06b70314b86bcadf95def8ea7b4b7f43> ;
    ns1:isUsingEUFunds false ;
    ns1:specifiesAwardCriterion <http://data.europa.eu/a4g/resource/id_a07d0944-e38d-4550-a27b-01b8afc3d24a-01_AwardCriterionPrice_ba3a06cb580fad2285928607282a4802> ;
