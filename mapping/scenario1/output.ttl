<http://data.europa.eu/a4g/resource/id_2022-S-025-064720_Lot_c1b4c2493eb9ccc693d4775d5ec29bd4> a ns1:Lot ;
    ns1:foreseesContractSpecificTerm <http://data.europa.eu/a4g/resource/id_2022-S-025-064720_ContractTermLot_c1b4c2493eb9ccc693d4775d5ec29bd4> ;
    ns1:hasDescription "Gegenstand der Vergabe hier ist Los 1 (Vertragsführung mit einer Führungsquote von 30%) der Kombinierten Bauleistungs-, Montage-, Haftpflicht- und Planungshaftpflichtversicherung für das Bauprojekt \"Schnellläuferprogramm Gera - Weischlitz\": Die DB Netz AG strebt die vollständige Ausrüstung des Schienennetzes mit digitaler Leit- und Sicherungstechnik (LST) im Rahmen des Zukunftsprogramms „Digitale Schiene Deutschland“ (DSD) bis 2035 an. Das Programm DSD soll durch das sogenannte „Schnellläuferprogramm“ (SLP) in den Jahren 2020 bis 2022 beschleunigt werden.Die Strecke 6269 Gera – Weischlitz ist eine teils eingleisige, teils zweigleisige, nichtelektrifizierte Strecke. Das Projekt beinhaltet den 1:1 Ersatz von Altstellwerken auf der Strecke 6269 durch Neubau von ESTW-A bzw. ESTW-Z und die Integration der aufgeführten Betriebsstellen (vgl. Tabelle 1/Tabelle 2), sowie Teile der angrenzenden Strecken in dieses Stellwerk.Die Investitionssumme für dieses Projekt mit einer derzeit geplanten Bauzeit bis 29.03.2024 wird mit ca. EUR 64 Mio. veranschlagt. Es wird mit einer derzeit geplanten Bauzeit bis zum 29.03.2024 gerechnet. Entsprechend ist die vorläufige Laufzeit des Versicherungsvertrags ebenfalls bis zum 29.03.2024 (zuzüglich Extended Maintenance und Nachhaftung) geplant."@de ;
    ns1:hasID <http://data.europa.eu/a4g/resource/id_2022-S-025-064720_LotIdentifier_c4ca4238a0b923820dcc509a6f75849b> ;
    ns1:hasPurpose <http://data.europa.eu/a4g/resource/id_2022-S-025-064720_LotPurpose_c1b4c2493eb9ccc693d4775d5ec29bd4> ;
    ns1:hasTitle "Los 1 (Vertragsführung) Kombinierte Bauleistungs-, Montage-, Haftpflicht- und Planungshaftpflichtversicherung für das Bauprojekt \"Schnellläuferprogramm Gera - Weischlitz\""@de ;
    ns1:isUsingEUFunds false ;
    ns1:specifiesAwardCriterion <http://data.europa.eu/a4g/resource/id_2022-S-025-064720_AwardCriterionPrice_05454844492d3bc28a4fe7f0654bc4cc> .

