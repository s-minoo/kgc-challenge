    ns3:description "Bent vienos Tiekėjo nurodytos ir techninėje specifikacijoje nustatytus reikalavimus atitinkančios specialiosios transporto priemonės išmetamas teršalų kiekis turi atitikti Euro 6 standartą."@lit ;
    ns3:name "aplinkosauginis reikalavimas"@lit ;
    ns3:weight "5" .

<http://data.europa.eu/a4g/resource/id_93da7e57-1661-4b17-915f-f7e45ee2e7c4-01_AwardCriterionQuality_de9a8d8e1faa0cf803b4b56605dd19652> a ns1:AwardCriterion ;
    ns1:hasAwardCriterionType <http://publications.europa.eu/resource/authority/award-criterion-type/quality> ;
    ns1:hasWeightValueType <http://publications.europa.eu/resource/authority/number-weight/per-exa> ;
    ns3:description "Sertifikavimo įstaigos, atitinkančios Europos Sąjungos teisės aktus arba tarptautinius sertifikavimo standartus, patvirtinti dokumentai, kad tiekėjas taiko aplinkos apsaugos vadybos sistemos reikalavimus pagal standartą LST EN ISO 14001 arba Europos Sąjungos aplinkosaugos vadybos ir audito sistemą (EMAS), ar kitus aplinkos apsaugos vadybos standartus, pagrįstus atitinkamais Europos arba tarptautiniais standartais. Pastaba. tiekėjo pateikti nesertifikuoti taikomų aplinkos apsaugos vadybos priemonių aprašymai nebus pripažįstami ir bus vertinami 0 balų"@lit ;
    ns3:name "aplinkosauginis reikalavimas"@lit ;
    ns3:weight "5" .

