    ns1:hasPerformingStaffQualificationInformation <http://publications.europa.eu/resource/authority/requirement-stage/not-requ> ;
    ns1:hasPurpose <http://data.europa.eu/a4g/resource/id_2021-S-001-000402_LotPurpose_2c52c25f6f424da86a7a4d8e178e076d> ;
    ns1:hasTitle "ΕΙΔΟΣ (ιι): Δεκατρία (13) οχήματα μεταφοράς σκύλων Κ-9 ανίχνευσης ναρκωτικών ουσιών"@el ;
