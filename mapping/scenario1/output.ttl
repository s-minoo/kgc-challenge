<http://data.europa.eu/a4g/resource/id_2022-S-045-113215_Procedure> a ns1:Procedure ;
    ns1:foreseesContractSpecificTerm <http://data.europa.eu/a4g/resource/id_2022-S-045-113215_ContractTermProcedure_f33bbb0c31774320fd507747e00189cd> ;
    ns1:hasAdditionalInformation "Tällä ilmoituksella on liitteitä/linkkejä osoitteessa https://www.hankintailmoitukset.fi/fi/public/procurement/66499/notice/94705"@fi ;
    ns1:hasDescription "Hankinnan kohteena on Helsingin Pihlajisto sijaitsevien asuinkerrostalojen peruskorjaus kiinteähintaisena kokonaisurakkana sisältäen rakennusteknisten töiden lisäksi kaikki LVISA-työt. Peruskorjauksen kohteena on Helsingin kaupungin asunnot Oy:n omistama vuokratalokohde, joka sijaitsee Helsingin kaupungin kaupungin osa nro 38. 305 tontti 3 ja 306 tontti 1 (Salpausseläntie 18 ja Aulangontie 2 ja 8-10)Rakennustyön arvioitu alkamisajankohta on 08/2022 ja työt tulee aloittaa viimeistään 09/2022Hankintaa ei jaeta osiin, sillä usean toimittajan malli tuottaisi epätarkoituksenmukaisen sopimuskokonaisuuden aikataulunhallinan sekä töiden yhteensovittamisen kannalta ja voisi vaarantaa edullisen kustannustason saavuttamisen."@fi ;
