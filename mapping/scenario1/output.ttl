<http://data.europa.eu/a4g/resource/id_2021-S-045-109465_Lot_9aef66ded86b0bf0a6fee30602e71a0d> a ns1:Lot ;
    ns1:foreseesContractSpecificTerm <http://data.europa.eu/a4g/resource/id_2021-S-045-109465_ContractTermLot_9aef66ded86b0bf0a6fee30602e71a0d> ;
    ns1:hasDescription "Hankkeessa toteutetaan Ranta-Toppilan satama-altaan rakentaminen, teräsponttirakenteiset laiturit, betoniset tukimuurit ja valaistukset, pilaantuneen maan ja sedimenttien kunnostukset satama- ja asemakaava-alueella sekä maisemakummun rakentaminen Ranta-Toppilan asemakaava-alueella. Työt toteutetaan urakka-asiakirjoissa esitetyssä laajuudessa. Satama-alueen lopullinen järjestely ja varustaminen jäävät ulkopuoliselle toimijalle. Urakan sisältö ja aikataulu on tarkemmin määritelty tarjouspyyntöasiakirjoissa."@fi ;
    ns1:hasID <http://data.europa.eu/a4g/resource/id_2021-S-045-109465_LotIdentifier_9aef66ded86b0bf0a6fee30602e71a0d> ;
