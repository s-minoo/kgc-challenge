    ns1:hasEOrdering false ;
    ns1:hasEPayment false ;
    ns1:hasPaymentArrangement """Izvršene usluge će se plaćati prema privremenim situacijama odnosno okončanoj situaciji, u postotku od izvršenih radova, a u roku od 30 dana od dana ovjere Naručitelja doznakom na poslovni račun Odabranog ponuditelja, odnosno prema aktivnostima, kako slijedi:
-	Stručni nadzor nad izvođenjem radova na rekonstrukciji i opremanju – hotel Bellevue = plaćanje temeljem privremenih i okončane situacije po izvedenom tehničkom pregledu, u postotku od izvršenih radova.
Obvezna je dostava e - Računa.
O roku, načinu i uvjetima plaćanja detaljnije je navedeno u zasebnom dokumentu naziva "Rok, način i uvjeti plaćanja"
"""@hrv ;
    ns1:hasPerformanceConditions "Nije definirano"@hrv ;
    ns1:hasReservedExecution <http://publications.europa.eu/resource/authority/applicability/no> .

