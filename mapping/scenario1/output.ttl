    ns1:hasSelectionCriterionType <http://publications.europa.eu/resource/authority/selection-criterion/tp-abil> ;
    ns1:isUsedForCandidateRestriction false ;
    ns3:description """De inschrijver beschikt over een vereiste vergunning om het verzekeringsbedrijf te mogen uitoefenen overeenkomstig de bepalingen van de Wet op het financieel toezicht (Wft) dan wel overeenkomstige wetgeving in het land van vestiging van inschrijver (de betreffende combinant).

Zie voor verdere uitwerking <paragraaf 3.3.1> van het aanbestedingsdocument."""@nld ;
    ns3:name "E2 <verzekeringen> Beroepsbevoegdheid"@nld .

<http://data.europa.eu/a4g/resource/id_f65bb8df-6e5c-42e5-96c0-60d3b423bf06-01_SelectionCriterion_8fa5abe1c431d0cd37db43bb0622cd6d> a ns1:SelectionCriterion ;
