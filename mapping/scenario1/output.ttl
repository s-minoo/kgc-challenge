    ns1:hasTitle "IGB03 1301-11 Estricharbeiten für das BV Gemeinsames Wissenschaftsgebäude Biodiversität IGB und FU auf dem Grundstück Königin-Luise-Str. 28-30 in 14195 Berlin."@de ;
    ns1:involvesBuyer <http://data.europa.eu/a4g/resource/id_2021-S-107-278403_Buyer_8b6b0d60d6b267bb5592d5ddd5e28185> ;
