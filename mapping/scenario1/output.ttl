    ns1:hasTitle "Los 2 (Vertragsbeteiligung) Kombinierte Bauleistungs-, Montage-, Haftpflicht- und Planungshaftpflichtversicherung für das Bauprojekt \"Schnellläuferprogramm Gera - Weischlitz\""@de ;
    ns1:isUsingEUFunds false ;
