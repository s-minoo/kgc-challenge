<http://data.europa.eu/m8g/Requirement> rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <http://data.europa.eu/m8g/description> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <http://data.europa.eu/m8g/name> ] .

epo:ExclusionGround a owl:Class ;
    rdfs:label "Exclusion ground"@en ;
    rdfs:comment """Describes a legal requirement to be met by the economic operator to be a candidate in the procurement procedure.

Additional Information:
This corresponds in eForms to BG-701 Exclusion Grounds.

WG approval 31/10/2018"""@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf epo:ProcurementCriterion ;
    owl:disjointWith epo:AwardCriterion,
        epo:SelectionCriterion ;
    skos:definition """Describes a legal requirement to be met by the economic operator to be a candidate in the procurement procedure.

Additional Information:
This corresponds in eForms to BG-701 Exclusion Grounds.

WG approval 31/10/2018"""@en ;
    skos:prefLabel "Exclusion ground"@en .

epo:NoticeChange a owl:Class ;
    rdfs:label "Notice change"@en ;
    rdfs:comment "Information about a corrigendum in a notice."@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:refersToPreviousNotice ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty epo:hasElementChange ],
        epo:NoticeDescription ;
    owl:disjointWith epo:ContractModification,
        epo:PublicationProvision ;
    skos:definition "Information about a corrigendum in a notice."@en ;
    skos:prefLabel "Notice change"@en .

epo:PurchaseContract a owl:Class ;
    rdfs:label "Purchase contract"@en ;
    rdfs:comment """A contract resulting from a Dynamic Purchasing System or Framework Agreement Contract.

Additional Information:
If BT-768  (Contract Framework Agreement) indicator is true, then epo:PurchaseContract class is instantiated. If its false, then epo:Contract class is instantiated. 
"""@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty epo:isWithinFrameworkAgreement ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:followsRulesSetBy ],
        epo:Contract ;
    owl:disjointWith epo:ConcessionContract,
        epo:FrameworkAgreement ;
    skos:definition """A contract resulting from a Dynamic Purchasing System or Framework Agreement Contract.

Additional Information:
If BT-768  (Contract Framework Agreement) indicator is true, then epo:PurchaseContract class is instantiated. If its false, then epo:Contract class is instantiated. 
"""@en ;
    skos:prefLabel "Purchase contract"@en .

epo:Purpose a owl:Class ;
    rdfs:label "Purpose"@en ;
    rdfs:comment """The description of the objectives related to a procurement. 

Additional information:

The description of the objectives includes the subject matter and quantities.


The quantification of the objectives related to a procurement.

To be re-reviewed by the WG the soonest.

(WG to be discussed, this was pointed out on the 09/04/2019 14:38:25 WG Meeting)

The old definition read as follows:

The description of the objectives related to a procurement.

(WG approval 05/12/2018)
"""@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasTotalQuantity ] ;
    skos:definition """The description of the objectives related to a procurement. 

Additional information:

The description of the objectives includes the subject matter and quantities.


The quantification of the objectives related to a procurement.

To be re-reviewed by the WG the soonest.

(WG to be discussed, this was pointed out on the 09/04/2019 14:38:25 WG Meeting)

The old definition read as follows:

The description of the objectives related to a procurement.

(WG approval 05/12/2018)
"""@en ;
    skos:prefLabel "Purpose"@en .

epo:StatisticalInformation owl:disjointWith epo:NoticeAwardInformation,
        epo:ProcurementProcessInformation .

epo:DirectAwardTerm rdfs:subClassOf epo:ProcedureSpecificTerm ;
    owl:disjointWith epo:AccessTerm,
        epo:FrameworkAgreementTerm,
        epo:ProcedureTerm,
        epo:ReviewTerm,
        epo:SubmissionTerm .

epo:Fund a owl:Class ;
    rdfs:label "Fund"@en ;
    rdfs:comment """A financial resource used to support the procurement.

Additional Information:

In the context of EU, funds can be divided into programmes, actions and projects.

Examples of EU funds are: the European Structural and Investment Funds, European Social Fund (ESF), the Connecting Europe Facility (CEF) programme, or the ISA2 programme and its actions (e.g. Action 2016.05 European Public Procurement Initiative, which supports the eProcurement Ontology under sub-action 3).

Funds may change between the lot and the contract, for example in the case of an emergency crisis, a contract may be financed by a budget that was not foreseen in the call.

WG Approved 14/05/2019




"""@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasID ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasURL ] ;
    skos:definition """A financial resource used to support the procurement.

Additional Information:

In the context of EU, funds can be divided into programmes, actions and projects.

Examples of EU funds are: the European Structural and Investment Funds, European Social Fund (ESF), the Connecting Europe Facility (CEF) programme, or the ISA2 programme and its actions (e.g. Action 2016.05 European Public Procurement Initiative, which supports the eProcurement Ontology under sub-action 3).

Funds may change between the lot and the contract, for example in the case of an emergency crisis, a contract may be financed by a budget that was not foreseen in the call.

WG Approved 14/05/2019




"""@en ;
    skos:prefLabel "Fund"@en .

epo:OrganisationGroup a owl:Class ;
    rdfs:label "Organisation group"@en ;
    rdfs:comment """Agreed collaboration of several organisations.
Additional Information:
This concept has been created to fulfill the need to represent a grouping of organisations that is not necessarily registered ie consortia.
WG approval 15/04/2021"""@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:leadBy ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty epo:hasMember ],
        org:Organization ;
    owl:disjointWith epo:Business,
        <http://data.europa.eu/m8g/PublicOrganisation> ;
    skos:definition """Agreed collaboration of several organisations.
Additional Information:
This concept has been created to fulfill the need to represent a grouping of organisations that is not necessarily registered ie consortia.
WG approval 15/04/2021"""@en ;
    skos:prefLabel "Organisation group"@en .

epo:ProcurementDocument a owl:Class ;
    rdfs:label "Procurement document"@en ;
    rdfs:comment """Document produced or referred to by the buyer to describe or determine elements of the procurement.

Additional information:

Procurement documents are to be accessible since the date of publication of the contract notice or the prior information notice when used as a call for competition.

Examples of procurement documents are technical specifications, the descriptive document, proposed conditions of contract, formats for the presentation of documents by candidates and tenderers, information on generally applicable obligations.

Other documents related to the procedure such as notices are not considered to be procurement documents.

WG Approval 23/05/2019 17:08:30"""@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf epo:Document ;
    owl:disjointWith epo:ExpressionOfInterest,
        epo:Notice,
        epo:RequestForClarification,
        epo:RequestForParticipation ;
    skos:definition """Document produced or referred to by the buyer to describe or determine elements of the procurement.

Additional information:

Procurement documents are to be accessible since the date of publication of the contract notice or the prior information notice when used as a call for competition.

Examples of procurement documents are technical specifications, the descriptive document, proposed conditions of contract, formats for the presentation of documents by candidates and tenderers, information on generally applicable obligations.

Other documents related to the procedure such as notices are not considered to be procurement documents.

WG Approval 23/05/2019 17:08:30"""@en ;
    skos:prefLabel "Procurement document"@en .

epo:ReviewRequestSummary a owl:Class ;
    rdfs:label "Review request summary"@en ;
    rdfs:comment """Summary information about the requests the buyer received to review any of its decisions (e.g. the technical specifications, award decision), as set out in Art. 1(5) of Directive 89/665/EEC and Directive 92/13/EEC, and about the complainants that submitted the requests.

Additional information:
This class corresponds  in eForms to BG-612     Buyer Review Summary."""@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty epo:concernsReviewSummaryForLot ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasTotalNumberOfComplainants ],
        epo:StatisticalInformation ;
    owl:disjointWith epo:ReviewIrregularitySummary,
        epo:SubmissionStatisticalInformation ;
    skos:definition """Summary information about the requests the buyer received to review any of its decisions (e.g. the technical specifications, award decision), as set out in Art. 1(5) of Directive 89/665/EEC and Directive 92/13/EEC, and about the complainants that submitted the requests.

Additional information:
This class corresponds  in eForms to BG-612     Buyer Review Summary."""@en ;
    skos:prefLabel "Review request summary"@en .

epo:TechniqueUsage rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasValidityPeriod ] .

<http://data.europa.eu/m8g/Constraint> a owl:Class ;
    rdfs:label "Constraint"@en ;
    rdfs:comment """Limitation applied to an Information Concept.

Additional Information:
Constraints are requirements in themselves, since they impose prerequisites which influence the definition, use and/or fulfilment of the requirement. They represent hard conditions such as minimum or maximum expressions which can be used to evaluate pieces of information, the required age, income, involvement in activities, etc. An example from the eProcurement domain is a threshold as the minimum turnover required by the buying organisation to select the candidates. Note that CCCEV does not provide any specific guidance on when which kind of Requirement should be used. Users of this vocabulary should make decisions on this topic in their specific context."""@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty epo:hasThresholdValue ],
        <http://data.europa.eu/m8g/Requirement> ;
    owl:disjointWith <http://data.europa.eu/m8g/Criterion> ;
    skos:definition """Limitation applied to an Information Concept.

Additional Information:
Constraints are requirements in themselves, since they impose prerequisites which influence the definition, use and/or fulfilment of the requirement. They represent hard conditions such as minimum or maximum expressions which can be used to evaluate pieces of information, the required age, income, involvement in activities, etc. An example from the eProcurement domain is a threshold as the minimum turnover required by the buying organisation to select the candidates. Note that CCCEV does not provide any specific guidance on when which kind of Requirement should be used. Users of this vocabulary should make decisions on this topic in their specific context."""@en ;
    skos:prefLabel "Constraint"@en .

<http://data.europa.eu/m8g/InformationConcept> a owl:Class ;
    rdfs:label "Information concept"@en ;
    rdfs:comment "Piece of information that the Evidence provides or the Requirement needs."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasID ] ;
    skos:definition "Piece of information that the Evidence provides or the Requirement needs."@en ;
    skos:prefLabel "Information concept"@en .

epo:AwardCriterion a owl:Class ;
    rdfs:label "Award criterion"@en ;
    rdfs:comment """Describes a requirement that the tender needs to resolve and on which the tender is evaluated and ranked.

(WG approval 05/11/2018)"""@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasFixedValue ],
        epo:ProcurementCriterion ;
    owl:disjointWith epo:ExclusionGround,
        epo:SelectionCriterion ;
    skos:definition """Describes a requirement that the tender needs to resolve and on which the tender is evaluated and ranked.

(WG approval 05/11/2018)"""@en ;
    skos:prefLabel "Award criterion"@en .

epo:AwardEvaluationTerm a owl:Class ;
    rdfs:label "Award evaluation term"@en ;
    rdfs:comment "Conditions and stipulations defining particularities of the evaluation of award criteria."@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasOverallQualityAwardCriteriaPonderation ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasOverallCostAwardCriteriaPonderation ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasAwardCriteriaOrderJustification ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasOverallPriceAwardCriteriaPonderation ],
        epo:EvaluationTerm ;
    owl:disjointWith epo:SelectionEvaluationTerm ;
    skos:definition "Conditions and stipulations defining particularities of the evaluation of award criteria."@en ;
    skos:prefLabel "Award evaluation term"@en .

epo:ContractSpecificTerm a owl:Class ;
    rdfs:label "Contract specific term"@en ;
    rdfs:comment "Gathering class for conditions and stipulations related to a contract in the post-award phase."@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf epo:Term ;
    owl:disjointWith epo:LotSpecificTerm,
        epo:ProcedureSpecificTerm,
        epo:ProcessPlanningTerm ;
    skos:definition "Gathering class for conditions and stipulations related to a contract in the post-award phase."@en ;
    skos:prefLabel "Contract specific term"@en .

epo:DesignContestRegimeTerm rdfs:subClassOf epo:LotSpecificTerm ;
    owl:disjointWith epo:AccessTerm,
        epo:FrameworkAgreementTerm,
        epo:MultipleStageProcedureTerm,
        epo:OpeningTerm,
        epo:ReviewTerm,
        epo:SubmissionTerm .

epo:GreenProcurement a owl:Class ;
    rdfs:label "Green procurement"@en ;
    rdfs:comment """Approach whereby buyers seek to procure with a reduced environmental impact.

Additional Information:

The approach may apply to the complete life cycle. The reduced environmental impact is in comparison to goods, services and works with the same primary function that would otherwise be procured. 

Tightly related are article 68 - Life-cycle costing and article 67 - most economically advantageous tender (see GPP handbook) https://ec.europa.eu/environment/gpp/pdf/Buying-Green-Handbook-3rd-Edition.pdf
An instance of the class GreenProcurement is represented in eForms with the code "env-imp" defined in the codelist strategic-procurement.paragraphs) https://ec.europa.eu/environment/gpp/pdf/Buying-Green-Handbook-3rd-Edition.pdf"""@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasZeroEmissionVehicles ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasCleanVehicles ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasTotalVehicles ],
        epo:StrategicProcurement ;
    owl:disjointWith epo:InnovativeProcurement,
        epo:SocialProcurement ;
    skos:definition """Approach whereby buyers seek to procure with a reduced environmental impact.

Additional Information:

The approach may apply to the complete life cycle. The reduced environmental impact is in comparison to goods, services and works with the same primary function that would otherwise be procured. 

Tightly related are article 68 - Life-cycle costing and article 67 - most economically advantageous tender (see GPP handbook) https://ec.europa.eu/environment/gpp/pdf/Buying-Green-Handbook-3rd-Edition.pdf
An instance of the class GreenProcurement is represented in eForms with the code "env-imp" defined in the codelist strategic-procurement.paragraphs) https://ec.europa.eu/environment/gpp/pdf/Buying-Green-Handbook-3rd-Edition.pdf"""@en ;
    skos:prefLabel "Green procurement"@en .

epo:ParticipationRequestTerm rdfs:subClassOf epo:LotSpecificTerm ;
    owl:disjointWith epo:AccessTerm,
        epo:FrameworkAgreementTerm,
        epo:MultipleStageProcedureTerm,
        epo:OpeningTerm,
        epo:ReviewTerm,
        epo:SubmissionTerm .

epo:ProcessPlanningTerm a owl:Class ;
    rdfs:label "Process planning term"@en ;
    rdfs:comment "Conditions and stipulations defining particularities of the unfolding of the procurement process."@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasEstimatedContractNoticePublicationDate ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasEstimatedTenderInvitationDate ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasAwardDateScheduled ],
        epo:Term ;
    owl:disjointWith epo:ContractSpecificTerm,
        epo:LotSpecificTerm,
        epo:ProcedureSpecificTerm ;
    skos:definition "Conditions and stipulations defining particularities of the unfolding of the procurement process."@en ;
    skos:prefLabel "Process planning term"@en .

epo:Business a owl:Class ;
    rdfs:label "Business"@en ;
    rdfs:comment """A private law company registered in a national registry.

WG Approval 28/04/2020

"""@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:isListedCompany ],
        org:Organization ;
    owl:disjointWith epo:OrganisationGroup,
        <http://data.europa.eu/m8g/PublicOrganisation> ;
    skos:definition """A private law company registered in a national registry.

WG Approval 28/04/2020

"""@en ;
    skos:prefLabel "Business"@en .

epo:EvaluationTerm rdfs:subClassOf epo:LotSpecificTerm ;
    owl:disjointWith epo:AccessTerm,
        epo:FrameworkAgreementTerm,
        epo:MultipleStageProcedureTerm,
        epo:OpeningTerm,
        epo:ReviewTerm,
        epo:SubmissionTerm .

epo:ProcurementProcessInformation a owl:Class ;
    rdfs:label "Procurement process information"@en ;
    rdfs:comment "Information about the temporal unfolding or succession of procurement objects."@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:isDPSTerminated ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:concernsProcedure ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:isCompetitionTerminated ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:isToBeRelaunched ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:concernsLot ],
        epo:ContextSpecificDescription ;
    owl:disjointWith epo:NoticeAwardInformation,
        epo:StatisticalInformation ;
    skos:definition "Information about the temporal unfolding or succession of procurement objects."@en ;
    skos:prefLabel "Procurement process information"@en .

epo:SecurityClearanceTerm rdfs:subClassOf epo:LotSpecificTerm ;
    owl:disjointWith epo:AccessTerm,
        epo:FrameworkAgreementTerm,
        epo:MultipleStageProcedureTerm,
        epo:OpeningTerm,
        epo:ReviewTerm,
        epo:SubmissionTerm .

epo:SelectionCriterion a owl:Class ;
    rdfs:label "Selection criterion"@en ;
    rdfs:comment """Describes a capacity requirement that the economic operator needs to fulfill to participate in the procedure.

Additional Information:
This corresponds in eForms to BG-702 Selection Criteria

WG approval 31/10/2018"""@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:isUsedForCandidateRestriction ],
        epo:ProcurementCriterion ;
    owl:disjointWith epo:AwardCriterion,
        epo:ExclusionGround ;
    skos:definition """Describes a capacity requirement that the economic operator needs to fulfill to participate in the procedure.

Additional Information:
This corresponds in eForms to BG-702 Selection Criteria

WG approval 31/10/2018"""@en ;
    skos:prefLabel "Selection criterion"@en .

epo:StrategicProcurement a owl:Class ;
    rdfs:label "Strategic procurement"@en ;
    rdfs:comment """Public procurement that contributes to achieving pressing policy goals.

Additional Information:
Specific strategic goals could be, for example, environmental protection, innovation, job creation and the development of small and medium enterprises.

This corresponds in eForms to BG-713 Strategic Procurement. The subclasses are given by the choices in BT-06  Strategic Procurement.

Based on https://legalinstruments.oecd.org/en/instruments/OECD-LEGAL-0411 (see paragraph on "background information".

WG Approval 10/03/2020"""@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    skos:definition """Public procurement that contributes to achieving pressing policy goals.

Additional Information:
Specific strategic goals could be, for example, environmental protection, innovation, job creation and the development of small and medium enterprises.

This corresponds in eForms to BG-713 Strategic Procurement. The subclasses are given by the choices in BT-06  Strategic Procurement.

Based on https://legalinstruments.oecd.org/en/instruments/OECD-LEGAL-0411 (see paragraph on "background information".

WG Approval 10/03/2020"""@en ;
    skos:prefLabel "Strategic procurement"@en .

epo:TenderAwardOutcome a owl:Class ;
    rdfs:label "Tender award outcome"@en ;
    rdfs:comment "Result concerning the Tender attributed by the awarder."@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasAwardRank ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty epo:describesTender ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:indicatesAwardOfLotToWinner ],
        epo:ContextualProjection ;
    owl:disjointWith epo:ContractLotCompletionInformation,
        epo:LotAwardOutcome,
        epo:LotGroupAwardInformation ;
    skos:definition "Result concerning the Tender attributed by the awarder."@en ;
    skos:prefLabel "Tender award outcome"@en .

epo:Contractor a owl:Class ;
    rdfs:label "Contractor"@en ;
    rdfs:comment """The role of an agent that has signed a contract with a Buyer.

WG approval 08/11/2022"""@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf epo:OfferingParty ;
    owl:disjointWith epo:CatalogueProvider,
        epo:OtherEntity,
        epo:ReviewRequester,
        epo:Subcontractor,
        epo:Tenderer,
        epo:Winner ;
    skos:definition """The role of an agent that has signed a contract with a Buyer.

WG approval 08/11/2022"""@en ;
    skos:prefLabel "Contractor"@en .

epo:NoticeAwardInformation a owl:Class ;
    rdfs:label "Notice award information"@en ;
    rdfs:comment "Information about an award notice."@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasProcurementLowestReceivedTenderValue ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasMaximumFrameworkAgreementAwardedValue ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasProcurementHighestReceivedTenderValue ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasTotalAwardedValue ],
        epo:ContextSpecificDescription ;
    owl:disjointWith epo:ProcurementProcessInformation,
        epo:StatisticalInformation ;
    skos:definition "Information about an award notice."@en ;
    skos:prefLabel "Notice award information"@en .

epo:Winner a owl:Class ;
    rdfs:label "Winner"@en ;
    rdfs:comment """A role of an agent to whom a lot is awarded.
WG approval 05/08/2021 (revised 26/10/2021)"""@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:dependsOnTenderer ],
        epo:OfferingParty ;
    owl:disjointWith epo:CatalogueProvider,
        epo:Contractor,
        epo:OtherEntity,
        epo:ReviewRequester,
        epo:Subcontractor,
        epo:Tenderer ;
    skos:definition """A role of an agent to whom a lot is awarded.
WG approval 05/08/2021 (revised 26/10/2021)"""@en ;
    skos:prefLabel "Winner"@en .

<http://data.europa.eu/m8g/Channel> a owl:Class ;
    rdfs:label "Channel"@en ;
    rdfs:comment """A medium through which an Agent provides, uses or interacts in another way with a Public Service. Typical examples include online services, phone, walk-in centres etc.

Additional Information
Software solutions and electronic devices for communication and exchange of information between buyers and economic operators.
Lots may use ad-hoc electronic means of communication that are not generally available such as specific solutions for secure and dedicated communication or non-standard eCatalogues.

See also Directive recitals 53 to 56.

WG Suggestion to eForms 30/09/2019


"""@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty epo:hasURL ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:isAdhocChannel ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasEndpoint ] ;
    skos:definition """A medium through which an Agent provides, uses or interacts in another way with a Public Service. Typical examples include online services, phone, walk-in centres etc.

Additional Information
Software solutions and electronic devices for communication and exchange of information between buyers and economic operators.
Lots may use ad-hoc electronic means of communication that are not generally available such as specific solutions for secure and dedicated communication or non-standard eCatalogues.

See also Directive recitals 53 to 56.

WG Suggestion to eForms 30/09/2019


"""@en ;
    skos:prefLabel "Channel"@en .

epo:AcquiringParty rdfs:subClassOf epo:AgentInRole .

epo:CatalogueReceiver owl:disjointWith epo:BudgetProvider,
        epo:Buyer,
        epo:Mediator,
        epo:PaymentExecutor,
        epo:ProcurementProcedureInformationProvider,
        epo:ProcurementServiceProvider,
        epo:ReviewProcedureInformationProvider,
        epo:Reviewer,
        epo:TenderReceiver .

epo:Document rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasDispatchDate ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasPublicationDate ] .

epo:OfflineAccessProvider owl:disjointWith epo:BudgetProvider,
        epo:Buyer,
        epo:Mediator,
        epo:PaymentExecutor,
        epo:ProcurementProcedureInformationProvider,
        epo:ProcurementServiceProvider,
        epo:ReviewProcedureInformationProvider,
        epo:Reviewer,
        epo:TenderReceiver .

epo:Tenderer a owl:Class ;
    rdfs:label "Tenderer"@en ;
    rdfs:comment """A role of an agent that has submitted a tender.

Additional Information:
A tenderer is an economic operator or group of economic operators that has submitted a tender.
WG approval 05/08/2021"""@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:substantiatesExclusionGround ],
        epo:OfferingParty ;
    owl:disjointWith epo:CatalogueProvider,
        epo:Contractor,
        epo:OtherEntity,
        epo:ReviewRequester,
        epo:Subcontractor,
        epo:Winner ;
    skos:definition """A role of an agent that has submitted a tender.

Additional Information:
A tenderer is an economic operator or group of economic operators that has submitted a tender.
WG approval 05/08/2021"""@en ;
    skos:prefLabel "Tenderer"@en .

<http://data.europa.eu/m8g/ContactPoint> a owl:Class ;
    rdfs:label "Contact point"@en ;
    rdfs:comment """Information (e.g. e-mail address, telephone number) of a person or department through which the user can get in touch with.

Additional information: 
This class represents the contact information for a Public Service, Channel, Public Organization, etc.
The contact point could be a role, email address, telephone number, etc.

WG approval 5/11/2019"""@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasContactName ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:address ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <http://data.europa.eu/m8g/email> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasInternetAddress ] ;
    skos:definition """Information (e.g. e-mail address, telephone number) of a person or department through which the user can get in touch with.

Additional information: 
This class represents the contact information for a Public Service, Channel, Public Organization, etc.
The contact point could be a role, email address, telephone number, etc.

WG approval 5/11/2019"""@en ;
    skos:prefLabel "Contact point"@en .

epo:AgentInRole a owl:Class ;
    rdfs:label "Agent in role"@en ;
    rdfs:comment """Relative concept that ties an agent to a part they play in a given situational context.

Additional information:
The classification of roles is based is based on the degree of involvement into the procurement process: 
- Primary (Procurement) role is directly involved in the procurement process;
- Secondary (Procurement sub-)role is secondary to the procurement process
- Tertiary (Related) role is not involved in the procurement process."""@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty epo:playedBy ] ;
    skos:definition """Relative concept that ties an agent to a part they play in a given situational context.

Additional information:
The classification of roles is based is based on the degree of involvement into the procurement process: 
- Primary (Procurement) role is directly involved in the procurement process;
- Secondary (Procurement sub-)role is secondary to the procurement process
- Tertiary (Related) role is not involved in the procurement process."""@en ;
    skos:prefLabel "Agent in role"@en .

epo:Awarder owl:disjointWith epo:BudgetProvider,
        epo:Buyer,
        epo:Mediator,
        epo:PaymentExecutor,
        epo:ProcurementProcedureInformationProvider,
        epo:ProcurementServiceProvider,
        epo:ReviewProcedureInformationProvider,
        epo:Reviewer,
        epo:TenderReceiver .

epo:ElementChangeDescription a owl:Class ;
    rdfs:label "Element change description"@en ;
    rdfs:comment "Information about a specific field to be changed with regard to a previous notice."@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasProcurementDocumentChangeDate ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:isProcurementDocumentChanged ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty epo:hasElementReference ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasPreviousVersionOfElementReference ],
        epo:ElementDescription ;
    owl:disjointWith epo:ElementConfidentialityDescription,
        epo:ElementModificationDescription ;
    skos:definition "Information about a specific field to be changed with regard to a previous notice."@en ;
    skos:prefLabel "Element change description"@en .

epo:LotGroup a owl:Class ;
    rdfs:label "Lot group"@en ;
    rdfs:comment """Combination of several lots to conduct comparative assessment of the tenders.

Additional Information:

The comparative assessment may refer to the selection criteria, award and value that apply to several lots.

Pending of discussion with eForms



Member States may provide that, where more than one lot may be awarded to the same tenderer, contracting authorities may award contracts combining several or all lots where they have specified in the contract notice or in the invitation to confirm interest that they reserve the possibility of doing so and indicate the lots or groups of lots that may be combined."""@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasEstimatedValue ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty epo:setsGroupingContextForLot ] ;
    skos:definition """Combination of several lots to conduct comparative assessment of the tenders.

Additional Information:

The comparative assessment may refer to the selection criteria, award and value that apply to several lots.

Pending of discussion with eForms



Member States may provide that, where more than one lot may be awarded to the same tenderer, contracting authorities may award contracts combining several or all lots where they have specified in the contract notice or in the invitation to confirm interest that they reserve the possibility of doing so and indicate the lots or groups of lots that may be combined."""@en ;
    skos:prefLabel "Lot group"@en .

epo:ProcedureSpecificTerm a owl:Class ;
    rdfs:label "Procedure specific term"@en ;
    rdfs:comment "Gathering class for conditions and stipulations related to a procedure."@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf epo:Term ;
    owl:disjointWith epo:ContractSpecificTerm,
        epo:LotSpecificTerm,
        epo:ProcessPlanningTerm ;
    skos:definition "Gathering class for conditions and stipulations related to a procedure."@en ;
    skos:prefLabel "Procedure specific term"@en .

epo:ParticipationRequestProcessor owl:disjointWith epo:BudgetProvider,
        epo:Buyer,
        epo:Mediator,
        epo:PaymentExecutor,
        epo:ProcurementProcedureInformationProvider,
        epo:ProcurementServiceProvider,
        epo:ReviewProcedureInformationProvider,
        epo:Reviewer,
        epo:TenderReceiver .

epo:ParticipationRequestReceiver owl:disjointWith epo:BudgetProvider,
        epo:Buyer,
        epo:Mediator,
        epo:PaymentExecutor,
        epo:ProcurementProcedureInformationProvider,
        epo:ProcurementServiceProvider,
        epo:ReviewProcedureInformationProvider,
        epo:Reviewer,
        epo:TenderReceiver .

epo:Period a owl:Class ;
    rdfs:label "Period"@en ;
    rdfs:comment """A time interval or a duration.

(WG approval 28/04/2020)
"""@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasBeginning ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasEnd ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasDescription ] ;
    skos:definition """A time interval or a duration.

(WG approval 28/04/2020)
"""@en ;
    skos:prefLabel "Period"@en .

epo:TenderProcessor owl:disjointWith epo:BudgetProvider,
        epo:Buyer,
        epo:Mediator,
        epo:PaymentExecutor,
        epo:ProcurementProcedureInformationProvider,
        epo:ProcurementServiceProvider,
        epo:ReviewProcedureInformationProvider,
        epo:Reviewer,
        epo:TenderReceiver .

epo:Quantity a owl:Class ;
    rdfs:label "Quantity"@en ;
    rdfs:comment """A counted number of non-monetary units possibly including fractions.
"""@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty epo:hasQuantityValue ] ;
    skos:definition """A counted number of non-monetary units possibly including fractions.
"""@en ;
    skos:prefLabel "Quantity"@en .

dct:Location a owl:Class ;
    rdfs:label "Location"@en ;
    rdfs:comment "An identifiable geographic place or named place."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:address ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:geometry ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <http://www.w3.org/ns/locn#geographicName> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:geographicIdentifier ] ;
    skos:definition "An identifiable geographic place or named place."@en ;
    skos:prefLabel "Location"@en .

epo:OpeningTerm a owl:Class ;
    rdfs:label "Opening term"@en ;
    rdfs:comment """Conditions and stipulations defining particularities of the opening of tenders.
Additional Information:
The opening of tenders is the event when tenders are made accessible for evaluation, it is generally the same date and time for all tenders.
WG Approval 15/04/2021"""@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasOpeningURL ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:definesOpeningPlace ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty epo:hasOpeningDateTime ],
        epo:LotSpecificTerm ;
    owl:disjointWith epo:AccessTerm,
        epo:DesignContestRegimeTerm,
        epo:EvaluationTerm,
        epo:FrameworkAgreementTerm,
        epo:MultipleStageProcedureTerm,
        epo:ParticipationRequestTerm,
        epo:ReviewTerm,
        epo:SecurityClearanceTerm,
        epo:SubmissionTerm ;
    skos:definition """Conditions and stipulations defining particularities of the opening of tenders.
Additional Information:
The opening of tenders is the event when tenders are made accessible for evaluation, it is generally the same date and time for all tenders.
WG Approval 15/04/2021"""@en ;
    skos:prefLabel "Opening term"@en .

epo:LotSpecificTerm a owl:Class ;
    rdfs:label "Lot specific term"@en ;
    rdfs:comment "Gathering class for conditions and stipulations related to a lot."@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf epo:Term ;
    owl:disjointWith epo:ContractSpecificTerm,
        epo:ProcedureSpecificTerm,
        epo:ProcessPlanningTerm ;
    skos:definition "Gathering class for conditions and stipulations related to a lot."@en ;
    skos:prefLabel "Lot specific term"@en .

epo:Mediator a owl:Class ;
    rdfs:label "Mediator"@en ;
    rdfs:comment """A role of an agent  that  attempts to resolve a dispute between different agents and come to an agreement.
WG approval 20/04/2021"""@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf epo:AcquiringParty ;
    owl:disjointWith epo:Awarder,
        epo:BudgetProvider,
        epo:Buyer,
        epo:CatalogueReceiver,
        epo:OfflineAccessProvider,
        epo:ParticipationRequestProcessor,
        epo:ParticipationRequestReceiver,
        epo:PaymentExecutor,
        epo:ProcurementProcedureInformationProvider,
        epo:ProcurementServiceProvider,
        epo:ReviewProcedureInformationProvider,
        epo:Reviewer,
        epo:TenderProcessor,
        epo:TenderReceiver ;
    skos:definition """A role of an agent  that  attempts to resolve a dispute between different agents and come to an agreement.
WG approval 20/04/2021"""@en ;
    skos:prefLabel "Mediator"@en .

epo:Notice a owl:Class ;
    rdfs:label "Notice"@en ;
    rdfs:comment """Document published by the buyer about market opportunities and results.

WG Approval 23/05/2019
"""@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty epo:refersToProcedure ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:refersToNotice ],
        epo:Document ;
    owl:disjointWith epo:ExpressionOfInterest,
        epo:ProcurementDocument,
        epo:RequestForClarification,
        epo:RequestForParticipation ;
    skos:definition """Document published by the buyer about market opportunities and results.

WG Approval 23/05/2019
"""@en ;
    skos:prefLabel "Notice"@en .

