            owl:onProperty epo:hasSchemeDataURI ] ;
    skos:definition """A character string to identify and distinguish uniquely, one instance of an object in an identification scheme from all other objects in the same scheme together with relevant supplementary information.
"""@en ;
    skos:prefLabel "Identifier"@en .

