        epo:SubmissionTerm ;
    skos:definition """Conditions and stipulations defining particularities of the review.

(WG approval 23/11/2018)
"""@en ;
    skos:prefLabel "Review term"@en .

epo:TenderReceiver a owl:Class ;
    rdfs:label "Tender receiver"@en ;
    rdfs:comment "A role of an agent responsible for receiving tenders."@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
