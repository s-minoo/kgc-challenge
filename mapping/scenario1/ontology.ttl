            owl:onProperty epo:hasAwardedValue ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasFrameworkAgreementMaximumValue ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasFrameworkAgreementEstimatedValue ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasAwardedEstimatedValue ],
        epo:ContextualProjection ;
    owl:disjointWith epo:ContractLotCompletionInformation,
        epo:LotGroupAwardInformation,
        epo:TenderAwardOutcome ;
    skos:definition "Result concerning the Lot attributed by the awarder."@en ;
    skos:prefLabel "Lot award outcome"@en .

epo:SubmissionStatisticalInformation a owl:Class ;
    rdfs:label "Submission statistical information"@en ;
    rdfs:comment "Statistical information about submissions on a given Lot. "@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasReceivedSmallTenders ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasHighestReceivedTenderValue ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasElectronicTenders ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasLowestReceivedTenderValue ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasMediumTenderPerLots ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasEEAReceivedTenders ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasUnverifiedTenders ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasReceivedNonEEATenders ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasEstimatedTotalSubcontracts ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty epo:hasEUReceivedTenders ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasReceivedMicroTenders ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasAbnormallyLowTenders ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty epo:summarisesInformationForLotAwardOutcome ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasReceivedSMETenders ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasReceivedTenders ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasNumberOfTenderersInvited ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasInadmissibleTenders ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty epo:hasReceivedNonEUTenders ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasReceivedParticipationRequests ],
        epo:StatisticalInformation ;
    owl:disjointWith epo:ReviewIrregularitySummary,
        epo:ReviewRequestSummary ;
    skos:definition "Statistical information about submissions on a given Lot. "@en ;
    skos:prefLabel "Submission statistical information"@en .

epo:Contract a owl:Class ;
    rdfs:label "Contract"@en ;
    rdfs:comment """A voluntary, deliberate, and legally binding agreement between two or more competent parties.

Additional information:

This includes concession contracts.

(WG approval 01/06/2018)"""@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasEntryIntoForceDate ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasEstimatedDuration ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasAccessURL ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasContractConclusionDate ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty epo:includesLot ],
        epo:ProcurementElement ;
    owl:disjointWith epo:AwardDecision,
        epo:ProcurementObject,
        epo:ReviewObject,
        epo:Tender ;
    skos:definition """A voluntary, deliberate, and legally binding agreement between two or more competent parties.

Additional information:

This includes concession contracts.

(WG approval 01/06/2018)"""@en ;
    skos:prefLabel "Contract"@en .

epo:ContractTerm a owl:Class ;
    rdfs:label "Contract term"@en ;
    rdfs:comment """Conditions and stipulations defining particularities of the post award phase.

(WG approval 23/11/2018)
"""@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasEInvoicing ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasContractorLegalFormRequirement ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:isRenewalIndicator ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasOptions ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:definesPaymentExecutor ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasMaximumNumberOfRenewals ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:definesContractDuration ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasEOrdering ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:definesSubcontractingTerm ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasEPayment ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:definesContractPeriod ],
        epo:ContractSpecificTerm ;
    owl:disjointWith epo:SubcontractTerm ;
    skos:definition """Conditions and stipulations defining particularities of the post award phase.

(WG approval 23/11/2018)
"""@en ;
    skos:prefLabel "Contract term"@en .

epo:Buyer a owl:Class ;
    rdfs:label "Buyer"@en ;
    rdfs:comment """A role of an agent that awards a contract and/or purchases items.

Additional information:
In public procurement the role of buyer is carried out by the following types of organisation: contracting authority, contracting entity, a defence contractor, an international organisation, or an organisation awarding a contract subsidized by a contracting authority.
In pre-award, the buyer generally awards the contract, however future purchasers may be foreseen.
In post-award the buyer generally refers to the purchaser of items."""@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:isContractingEntity ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasBuyerProfile ],
        epo:AcquiringParty ;
    owl:disjointWith epo:Awarder,
        epo:BudgetProvider,
        epo:CatalogueReceiver,
        epo:Mediator,
        epo:OfflineAccessProvider,
        epo:ParticipationRequestProcessor,
        epo:ParticipationRequestReceiver,
        epo:PaymentExecutor,
        epo:ProcurementProcedureInformationProvider,
        epo:ProcurementServiceProvider,
        epo:ReviewProcedureInformationProvider,
        epo:Reviewer,
        epo:TenderProcessor,
        epo:TenderReceiver ;
    skos:definition """A role of an agent that awards a contract and/or purchases items.

Additional information:
In public procurement the role of buyer is carried out by the following types of organisation: contracting authority, contracting entity, a defence contractor, an international organisation, or an organisation awarding a contract subsidized by a contracting authority.
In pre-award, the buyer generally awards the contract, however future purchasers may be foreseen.
In post-award the buyer generally refers to the purchaser of items."""@en ;
    skos:prefLabel "Buyer"@en .

epo:SubmissionTerm a owl:Class ;
    rdfs:label "Submission term"@en ;
    rdfs:comment """Conditions and stipulations defining particularities of submitting documents to the buyer. 

Additional Information: 
These documents can be tenders, request to participate and expressions of interest.

WG Approval 14/07/2020"""@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:definesTenderReceiver ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasEAuctionURL ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:isGuaranteeRequired ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:definesTenderProcessor ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty epo:hasReceiptDeadline ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:isAdvancedElectronicSignatureRequired ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasValidityPeriod ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:isMultipleTenderSubmissionAllowed ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasReceiptExpressionDeadline ],
        epo:LotSpecificTerm,
        epo:ProcedureSpecificTerm ;
    owl:disjointWith epo:AccessTerm,
        epo:DesignContestRegimeTerm,
        epo:DirectAwardTerm,
        epo:EvaluationTerm,
        epo:FrameworkAgreementTerm,
        epo:MultipleStageProcedureTerm,
        epo:OpeningTerm,
        epo:ParticipationRequestTerm,
        epo:ProcedureTerm,
        epo:ReviewTerm,
        epo:SecurityClearanceTerm ;
    skos:definition """Conditions and stipulations defining particularities of submitting documents to the buyer. 

Additional Information: 
These documents can be tenders, request to participate and expressions of interest.

WG Approval 14/07/2020"""@en ;
    skos:prefLabel "Submission term"@en .

epo:MonetaryValue a owl:Class ;
    rdfs:label "Monetary value"@en ;
    rdfs:comment """A number of monetary units specified using a given unit of currency.

WG approval 13/04/2021
"""@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty epo:hasAmountValue ] ;
    skos:definition """A number of monetary units specified using a given unit of currency.

WG approval 13/04/2021
"""@en ;
    skos:prefLabel "Monetary value"@en .

<http://data.europa.eu/m8g/constrains>
  a owl:ObjectProperty ;
  rdfs:label "constrains"@en ;
  rdfs:comment "Information Concept about which a Constraint expresses a limitation."@en ;
  rdfs:domain <http://data.europa.eu/m8g/Constraint> ;
  rdfs:isDefinedBy <http://data.europa.eu/m8g> ;
  rdfs:range <http://data.europa.eu/m8g/InformationConcept> ;
  skos:scopeNote "Information Concepts are tools to make Requirements more machine processable: they allow to provide more detail about a Requirement. This way, Constraints can be made very precise, namely the limit that must be achieved, is a limit on the value for the associated Information Concept. For example, the Information Concept would be the age of a person and the Constraint would be the required age in the context of a specific evaluation."@en .

dct:type a owl:DatatypeProperty ;
    rdfs:domain epo:ExclusionGround ;
    rdfs:label "Type"@en ;
    rdfs:comment "The nature or genre of the resource."@en ;
    dct:description "Recommended practice is to use a controlled vocabulary such as the DCMI Type Vocabulary [[DCMI-TYPE](http://dublincore.org/documents/dcmi-type-vocabulary/)]. To describe the file format, physical medium, or dimensions of the resource, use the property Format."@en ;
    rdfs:isDefinedBy <http://purl.org/dc/terms/> ;
    rdfs:range xsd:string .

locn:address a owl:ObjectProperty ;
    rdfs:domain dct:Location ;
    rdfs:range locn:Address ;
    rdfs:label "address"@en ;
    rdfs:comment "The locn:address property relationship associates any resource with the locn:Address class "@en ;
    rdfs:isDefinedBy <http://www.w3.org/ns/locn> .