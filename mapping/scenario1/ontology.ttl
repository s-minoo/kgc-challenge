@prefix dct: <http://purl.org/dc/terms/> .
@prefix epo: <http://data.europa.eu/a4g/ontology#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix cccev: <http://data.europa.eu/m8g/> .
@prefix locn: <http://www.w3.org/ns/locn#> .


epo:CentralPurchasingBody rdfs:subClassOf epo:Buyer .

epo:LeadBuyer rdfs:subClassOf epo:Buyer .

epo:announcesContract a owl:ObjectProperty ;
    rdfs:label "Announces contract"@en ;
    rdfs:domain epo:ResultNotice ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range epo:Contract ;
    skos:prefLabel "Announces contract"@en .

epo:announcesLot a owl:ObjectProperty ;
    rdfs:label "Announces lot"@en ;
    rdfs:domain epo:CompetitionNotice ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range epo:Lot ;
    skos:prefLabel "Announces lot"@en .

epo:announcesLotAwardOutcome a owl:ObjectProperty ;
    rdfs:label "Announces lot award outcome"@en ;
    rdfs:domain epo:ResultNotice ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range epo:LotAwardOutcome ;
    skos:prefLabel "Announces lot award outcome"@en .

epo:announcesLotGroup a owl:ObjectProperty ;
    rdfs:label "Announces lot group"@en ;
    rdfs:domain epo:CompetitionNotice ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range epo:LotGroup ;
    skos:prefLabel "Announces lot group"@en .

epo:announcesLotGroupAwardInformation rdfs:domain epo:ResultNotice .

epo:announcesNonPublishedElement rdfs:domain epo:ResultNotice .

epo:announcesNoticeAwardInformation a owl:ObjectProperty ;
    rdfs:label "Announces notice award information"@en ;
    rdfs:domain epo:ResultNotice ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range epo:NoticeAwardInformation ;
    skos:prefLabel "Announces notice award information"@en .

epo:announcesProcedure a owl:ObjectProperty ;
    rdfs:label "Announces procedure"@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( epo:DirectAwardPrenotificationNotice epo:CompetitionNotice ) ] ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( epo:Procedure ) ] ;
    skos:prefLabel "Announces procedure"@en .

epo:announcesRole a owl:ObjectProperty ;
    rdfs:label "Announces role"@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( epo:ResultNotice epo:CompetitionNotice ) ] ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( epo:AgentInRole ) ] ;
    skos:prefLabel "Announces role"@en .

epo:announcesTender a owl:ObjectProperty ;
    rdfs:label "Announces tender"@en ;
    rdfs:domain epo:ResultNotice ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range epo:Tender ;
    skos:prefLabel "Announces tender"@en .

epo:bindsBuyer a owl:ObjectProperty ;
    rdfs:label "Binds buyer"@en ;
    rdfs:comment "Provides legal constraint on the Buyer. (epo:Contract -> epo:Buyer (+epo:bindsBuyer)) "@en ;
    rdfs:domain epo:Contract ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range epo:Buyer ;
    skos:definition "Provides legal constraint on the Buyer. (epo:Contract -> epo:Buyer (+epo:bindsBuyer)) "@en ;
    skos:prefLabel "Binds buyer"@en .

epo:bindsContractor a owl:ObjectProperty ;
    rdfs:label "Binds contractor"@en ;
    rdfs:comment "Provides legal constraint on the Contractor. (epo:Contract -> epo:Contractor (+epo:bindsContractor)) "@en ;
    rdfs:domain epo:Contract ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range epo:Contractor ;
    skos:definition "Provides legal constraint on the Contractor. (epo:Contract -> epo:Contractor (+epo:bindsContractor)) "@en ;
    skos:prefLabel "Binds contractor"@en .

epo:comprisesLotAwardOutcome rdfs:range epo:LotAwardOutcome .

epo:comprisesTender rdfs:range epo:Tender .

epo:comprisesTenderAwardOutcome a owl:ObjectProperty ;
    rdfs:label "Comprises tender award outcome"@en ;
    rdfs:comment "Incorporates TenderAwardOutcome. (epo:LotAwardOutcome -> epo:TenderAwardOutcome (+epo:comprisesTenderAwardOutcome)) "@en ;
    rdfs:domain epo:LotAwardOutcome ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range epo:TenderAwardOutcome ;
    skos:definition "Incorporates TenderAwardOutcome. (epo:LotAwardOutcome -> epo:TenderAwardOutcome (+epo:comprisesTenderAwardOutcome)) "@en ;
    skos:prefLabel "Comprises tender award outcome"@en .

epo:concernsContract rdfs:range epo:Contract .

epo:concernsPlaceOfDelivery rdfs:range dct:Location .

epo:concernsPlaceOfStorage rdfs:range dct:Location .

epo:constrains rdfs:domain <http://data.europa.eu/m8g/Constraint> ;
    rdfs:range <http://data.europa.eu/m8g/InformationConcept> .

epo:contextualisedBy rdfs:domain epo:AgentInRole .

epo:definesCatalogueProvider rdfs:domain epo:AccessTerm .

epo:definesCatalogueReceiver rdfs:domain epo:AccessTerm .

epo:definesInformationProvider rdfs:domain epo:ProcedureTerm .

epo:definesLotGroup a owl:ObjectProperty ;
    rdfs:label "Defines lot group"@en ;
    rdfs:comment "Relation indicating a ProcedureTerm has a LotGroup. (epo:ProcedureTerm -> epo:LotGroup (+epo:definesLotGroup)) "@en ;
    rdfs:domain epo:ProcedureTerm ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range epo:LotGroup ;
    skos:definition "Relation indicating a ProcedureTerm has a LotGroup. (epo:ProcedureTerm -> epo:LotGroup (+epo:definesLotGroup)) "@en ;
    skos:prefLabel "Defines lot group"@en .

epo:definesReviewer a owl:ObjectProperty ;
    rdfs:label "Defines reviewer"@en ;
    rdfs:comment "Relation indicating a ReviewTerm has a Reviewer. (epo:ReviewTerm -> epo:Reviewer (+epo:definesReviewer)) "@en ;
    rdfs:domain epo:ReviewTerm ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range epo:Reviewer ;
    skos:definition "Relation indicating a ReviewTerm has a Reviewer. (epo:ReviewTerm -> epo:Reviewer (+epo:definesReviewer)) "@en ;
    skos:prefLabel "Defines reviewer"@en .

epo:definesSpecificPlaceOfPerformance a owl:ObjectProperty ;
    rdfs:label "Defines specific place of performance"@en ;
    rdfs:comment "Relation indicating a ContractTerm has a specific place of performance. (epo:ContractTerm -> dct:Location (+epo:definesSpecificPlaceOfPerformance)) "@en ;
    rdfs:domain epo:ContractTerm ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range dct:Location ;
    skos:definition "Relation indicating a ContractTerm has a specific place of performance. (epo:ContractTerm -> dct:Location (+epo:definesSpecificPlaceOfPerformance)) "@en ;
    skos:prefLabel "Defines specific place of performance"@en .

epo:delegatesAncillaryActivitiesTo rdfs:domain epo:Buyer ;
    rdfs:range epo:ProcurementServiceProvider .

epo:describesLotCompletion rdfs:range epo:Lot .

epo:describesLotGroup rdfs:range epo:LotGroup .

epo:describesResultNotice rdfs:domain epo:NoticeAwardInformation ;
    rdfs:range epo:ResultNotice .

epo:foreseesContractSpecificTerm a owl:ObjectProperty ;
    rdfs:label "Foresees contract specific term"@en ;
    rdfs:domain epo:ProcurementObject ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range epo:ContractSpecificTerm ;
    skos:prefLabel "Foresees contract specific term"@en .

epo:foreseesSubcontracting rdfs:domain epo:Tender .

epo:fulfillsRequirement a owl:ObjectProperty ;
    rdfs:label "Fulfills requirement"@en ;
    rdfs:comment """The requirement to which the concept meets.
WG Approval 09/11/2021

The codelist to be used is at-voc:environmental-impact which is available at http://publications.europa.eu/resource/dataset/environmental-impact (epo:GreenProcurement -> at-voc:environmental-impact (+epo:fulfillsRequirement)) The requirement to which the concept meets.
WG Approval 09/11/2021

The codelist to be used is at-voc:innovative-acquisition which is available at http://publications.europa.eu/resource/dataset/innovative-acquisition (epo:InnovativeProcurement -> at-voc:innovative-acquisition (+epo:fulfillsRequirement)) The requirement to which the concept meets.
WG Approval 09/11/2021

The codelist to be used is at-voc:social-objective which is available at http://publications.europa.eu/resource/dataset/social-objective (epo:SocialProcurement -> at-voc:social-objective (+epo:fulfillsRequirement)) """@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( epo:GreenProcurement epo:InnovativeProcurement epo:SocialProcurement ) ] ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range <skos:Concept> ;
    skos:prefLabel "Fulfills requirement"@en ;
    skos:scopeNote """The requirement to which the concept meets.
WG Approval 09/11/2021

The codelist to be used is at-voc:environmental-impact which is available at http://publications.europa.eu/resource/dataset/environmental-impact (epo:GreenProcurement -> at-voc:environmental-impact (+epo:fulfillsRequirement)) The requirement to which the concept meets.
WG Approval 09/11/2021

The codelist to be used is at-voc:innovative-acquisition which is available at http://publications.europa.eu/resource/dataset/innovative-acquisition (epo:InnovativeProcurement -> at-voc:innovative-acquisition (+epo:fulfillsRequirement)) The requirement to which the concept meets.
WG Approval 09/11/2021

The codelist to be used is at-voc:social-objective which is available at http://publications.europa.eu/resource/dataset/social-objective (epo:SocialProcurement -> at-voc:social-objective (+epo:fulfillsRequirement)) """@en .

epo:fulfillsStrategicProcurement a owl:ObjectProperty ;
    rdfs:label "Fulfills strategic procurement"@en ;
    rdfs:domain epo:ProcurementObject ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range epo:StrategicProcurement ;
    skos:prefLabel "Fulfills strategic procurement"@en .

epo:hasAcceleratedProcedureJustification a owl:DatatypeProperty ;
    rdfs:label "Has accelerated procedure justification"@en ;
    rdfs:comment """The reasons why the procedure is accelerated.

Additional Information:
A procedure is accelerated to cover needs of extraordinary circumstances ie earthquake relief.

WG Approval 09/06/2020

 (epo:Procedure) """@en ;
    rdfs:domain epo:Procedure ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range rdfs:Literal ;
    skos:definition """The reasons why the procedure is accelerated.

Additional Information:
A procedure is accelerated to cover needs of extraordinary circumstances ie earthquake relief.

WG Approval 09/06/2020

 (epo:Procedure) """@en ;
    skos:prefLabel "Has accelerated procedure justification"@en .

epo:hasAccessibilityDate rdfs:range xsd:date .

epo:hasActivityDescription rdfs:domain epo:Buyer .

epo:hasAdditionalClassification a owl:ObjectProperty ;
    rdfs:label "Has additional classification"@en ;
    rdfs:comment """The codelist to be used is at-voc:cpv which is available at http://publications.europa.eu/resource/dataset/cpv
 (epo:Purpose -> at-voc:cpv (+epo:hasAdditionalClassification)) The codelist to be used is at-voc:cpv which is available at http://publications.europa.eu/resource/dataset/cpv (epo:Purpose -> at-voc:cpvsuppl (+epo:hasAdditionalClassification)) """@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( epo:Purpose ) ] ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range <skos:Concept> ;
    skos:definition """The codelist to be used is at-voc:cpv which is available at http://publications.europa.eu/resource/dataset/cpv
 (epo:Purpose -> at-voc:cpv (+epo:hasAdditionalClassification)) The codelist to be used is at-voc:cpv which is available at http://publications.europa.eu/resource/dataset/cpv (epo:Purpose -> at-voc:cpvsuppl (+epo:hasAdditionalClassification)) """@en ;
    skos:prefLabel "Has additional classification"@en .

epo:hasAdditionalContractNature a owl:ObjectProperty ;
    rdfs:label "Has additional contract nature"@en ;
    rdfs:comment """
 (epo:ContractTerm -> at-voc:contract-nature (+epo:hasAdditionalContractNature)) """@en,
        """Additional type of acquisition taken into consideration in the contract.

WG Approval 11/06/2020

The codelist to be used is at-voc:contract-nature which is available at http://publications.europa.eu/resource/dataset/contract-nature (epo:ContractTerm -> at-voc:contract-nature (+epo:hasAdditionalContractNature)) """@en ;
    rdfs:domain epo:ContractTerm ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range <skos:Concept> ;
    skos:definition """
 (epo:ContractTerm -> at-voc:contract-nature (+epo:hasAdditionalContractNature)) """@en ;
    skos:prefLabel "Has additional contract nature"@en ;
    skos:scopeNote """Additional type of acquisition taken into consideration in the contract.

WG Approval 11/06/2020

The codelist to be used is at-voc:contract-nature which is available at http://publications.europa.eu/resource/dataset/contract-nature (epo:ContractTerm -> at-voc:contract-nature (+epo:hasAdditionalContractNature)) """@en .

epo:hasAdditionalInformation a owl:DatatypeProperty ;
    rdfs:label "Has additional information"@en ;
    rdfs:comment """Supplementary data about the instance of the concept.

Additional Information

For example, information about the Lot not specified elsewhere in the Notice.

WG Approval 15/10/2019
 (cv:Channel) Supplementary data about the instance of the concept.

Additional Information

For example, information about the Lot not specified elsewhere in the Notice.

WG Approval 15/10/2019 (epo:ProcurementObject) """@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( <http://data.europa.eu/m8g/Channel> epo:ProcurementObject ) ] ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range rdfs:Literal ;
    skos:definition """Supplementary data about the instance of the concept.

Additional Information

For example, information about the Lot not specified elsewhere in the Notice.

WG Approval 15/10/2019
 (cv:Channel) Supplementary data about the instance of the concept.

Additional Information

For example, information about the Lot not specified elsewhere in the Notice.

WG Approval 15/10/2019 (epo:ProcurementObject) """@en ;
    skos:prefLabel "Has additional information"@en .

epo:hasAwardCriteriaEvaluationFormula a owl:DatatypeProperty ;
    rdfs:label "Has award criteria evaluation formula"@en ;
    rdfs:comment """The mathematical equation or any other description used for complicated weighing of criteria (e.g. non-linear weighing, the analytic hierarchy process) when a weighing cannot be expressed per criterion. 

Additional Information: 
This corresponds in eForms to BT-543 Award Criteria Complicated. (epo:AwardEvaluationTerm) """@en ;
    rdfs:domain epo:AwardEvaluationTerm ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range rdfs:Literal ;
    skos:definition """The mathematical equation or any other description used for complicated weighing of criteria (e.g. non-linear weighing, the analytic hierarchy process) when a weighing cannot be expressed per criterion. 

Additional Information: 
This corresponds in eForms to BT-543 Award Criteria Complicated. (epo:AwardEvaluationTerm) """@en ;
    skos:prefLabel "Has award criteria evaluation formula"@en .

epo:hasAwardCriterionType a owl:ObjectProperty ;
    rdfs:label "Has award criterion type"@en ;
    rdfs:comment """Category of award criterion.

The codelist to be used is at-voc:award-criterion-type which is available at http://publications.europa.eu/resource/dataset/award-criterion-type (epo:AwardCriterion -> at-voc:award-criterion-type (+epo:hasAwardCriterionType)) """@en ;
    rdfs:domain epo:AwardCriterion ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range <skos:Concept> ;
    skos:prefLabel "Has award criterion type"@en ;
    skos:scopeNote """Category of award criterion.

The codelist to be used is at-voc:award-criterion-type which is available at http://publications.europa.eu/resource/dataset/award-criterion-type (epo:AwardCriterion -> at-voc:award-criterion-type (+epo:hasAwardCriterionType)) """@en .

epo:hasAwardStatus a owl:ObjectProperty ;
    rdfs:label "Has award status"@en ;
    rdfs:comment """Indicates whether the lot is awarded, not awarded or still open.

WG Approval 03/12/2019

The codelist to be used is at-voc:winner-selection-status which is available at http://publications.europa.eu/resource/dataset/winner-selection-status
 (epo:LotAwardOutcome -> at-voc:winner-selection-status (+epo:hasAwardStatus)) """@en ;
    rdfs:domain epo:LotAwardOutcome ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range <skos:Concept> ;
    skos:prefLabel "Has award status"@en ;
    skos:scopeNote """Indicates whether the lot is awarded, not awarded or still open.

WG Approval 03/12/2019

The codelist to be used is at-voc:winner-selection-status which is available at http://publications.europa.eu/resource/dataset/winner-selection-status
 (epo:LotAwardOutcome -> at-voc:winner-selection-status (+epo:hasAwardStatus)) """@en .

epo:hasBaseQuantity rdfs:range epo:Quantity .

epo:hasBeneficialOwner rdfs:domain epo:Business .

epo:hasBroadPlaceOfPerformance a owl:ObjectProperty ;
    rdfs:label "Has broad place of performance"@en ;
    rdfs:comment """Geopolitical zone where the contract can be executed.

Additional Information

Used for setting restrictions that cannot be established with one country code or a geographical zone identifier (like NUTS), because they have a broader scope (geographical, economic, political, other).

The codelist to be used is at-voc:other-place-service which is available at http://publications.europa.eu/resource/dataset/other-place-service (epo:ContractTerm -> at-voc:other-place-service (+epo:hasBroadPlaceOfPerformance)) """@en ;
    rdfs:domain epo:ContractTerm ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range <skos:Concept> ;
    skos:prefLabel "Has broad place of performance"@en ;
    skos:scopeNote """Geopolitical zone where the contract can be executed.

Additional Information

Used for setting restrictions that cannot be established with one country code or a geographical zone identifier (like NUTS), because they have a broader scope (geographical, economic, political, other).

The codelist to be used is at-voc:other-place-service which is available at http://publications.europa.eu/resource/dataset/other-place-service (epo:ContractTerm -> at-voc:other-place-service (+epo:hasBroadPlaceOfPerformance)) """@en .

epo:hasBusinessSize a owl:ObjectProperty ;
    rdfs:label "Has business size"@en ;
    rdfs:comment """The category of the business depending on number of employees and turnover.

Additional information:

See Commission Recommendation of 6 May 2003 concerning the definition of micro, small and medium-sized enterprises.

ELI: http://data.europa.eu/eli/reco/2003/361/oj

WG Approval 28/05/2020

The codelist to be used is at-voc:economic-operator-size which is available at http://publications.europa.eu/resource/dataset/economic-operator-size (epo:Business -> at-voc:economic-operator-size (+epo:hasBusinessSize)) """@en ;
    rdfs:domain epo:Business ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range <skos:Concept> ;
    skos:prefLabel "Has business size"@en ;
    skos:scopeNote """The category of the business depending on number of employees and turnover.

Additional information:

See Commission Recommendation of 6 May 2003 concerning the definition of micro, small and medium-sized enterprises.

ELI: http://data.europa.eu/eli/reco/2003/361/oj

WG Approval 28/05/2020

The codelist to be used is at-voc:economic-operator-size which is available at http://publications.europa.eu/resource/dataset/economic-operator-size (epo:Business -> at-voc:economic-operator-size (+epo:hasBusinessSize)) """@en .

epo:hasBuyerCategoryDescription a owl:DatatypeProperty ;
    rdfs:label "Has buyer category description"@en ;
    rdfs:comment """A classification of buyers participating in a framework agreement.

Additional Information:
Buyers that can use the Framework Agreement not mentioned by name.

For example, the classification "all hospitals in the Tuscany region" is used instead of naming each individual buyer.

This corresponds in eForms to BT-111 Framework Buyer Categories.

WG Approval 2019-05-06 (epo:FrameworkAgreementTerm) """@en ;
    rdfs:domain epo:FrameworkAgreementTerm ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range rdfs:Literal ;
    skos:definition """A classification of buyers participating in a framework agreement.

Additional Information:
Buyers that can use the Framework Agreement not mentioned by name.

For example, the classification "all hospitals in the Tuscany region" is used instead of naming each individual buyer.

This corresponds in eForms to BT-111 Framework Buyer Categories.

WG Approval 2019-05-06 (epo:FrameworkAgreementTerm) """@en ;
    skos:prefLabel "Has buyer category description"@en .

epo:hasBuyerItemID rdfs:range epo:Identifier .

epo:hasBuyerLegalType a owl:ObjectProperty ;
    rdfs:label "Has buyer legal type"@en ;
    rdfs:comment """A category that indicates the right of an organisation to play the role of a buyer.

Additional Information:
The category also effects the rules that the buyer has to abide to within the public procurement procedure.
WG 07/09/2021

The codelist to be used is at-voc:buyer-legal-type which is available at http://publications.europa.eu/resource/dataset/buyer-legal-type (org:Organization -> at-voc:buyer-legal-type (+epo:hasBuyerLegalType)) """@en ;
    rdfs:domain org:Organization ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range <skos:Concept> ;
    skos:definition """A category that indicates the right of an organisation to play the role of a buyer.

Additional Information:
The category also effects the rules that the buyer has to abide to within the public procurement procedure.
WG 07/09/2021

The codelist to be used is at-voc:buyer-legal-type which is available at http://publications.europa.eu/resource/dataset/buyer-legal-type (org:Organization -> at-voc:buyer-legal-type (+epo:hasBuyerLegalType)) """@en ;
    skos:prefLabel "Has buyer legal type"@en .

epo:hasCatalogueItemID rdfs:range epo:Identifier .

epo:hasCatalogueLineValidity rdfs:range epo:Period .

epo:hasChangeDescription a owl:DatatypeProperty ;
    rdfs:label "Has change description"@en ;
    rdfs:comment """Explanatory text about the instance of the concept.

WG Approval 30/09/2019 (epo:ElementChangeDescription) """@en ;
    rdfs:domain epo:ElementChangeDescription ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range rdfs:Literal ;
    skos:definition """Explanatory text about the instance of the concept.

WG Approval 30/09/2019 (epo:ElementChangeDescription) """@en ;
    skos:prefLabel "Has change description"@en .

epo:hasChangeJustification a owl:ObjectProperty ;
    rdfs:label "Has change justification"@en ;
    rdfs:comment """Code explaining the change.

Additional Information:
The codelist to be used is at-voc:change-corrig-justification which is available at 
http://publications.europa.eu/resource/dataset/change-corrig-justification

WG Approval 5/11/2019
 (epo:ElementChangeDescription -> at-voc:change-corrig-justification (+epo:hasChangeJustification)) """@en,
        """The motives for the change.

WG 5/11/2019

The codelist to be used is at-voc:change-corrig-justification which is available at 
http://publications.europa.eu/resource/dataset/change-corrig-justification (epo:ElementChangeDescription -> at-voc:change-corrig-justification (+epo:hasChangeJustification)) """@en ;
    rdfs:domain epo:ElementChangeDescription ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range <skos:Concept> ;
    skos:definition """Code explaining the change.

Additional Information:
The codelist to be used is at-voc:change-corrig-justification which is available at 
