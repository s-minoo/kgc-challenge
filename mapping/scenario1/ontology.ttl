epo:MultipleStageProcedureTerm a owl:Class ;
    rdfs:label "Multiple stage procedure term"@en ;
    rdfs:comment """Conditions and stipulations defining particularities of procedures carried out in several steps
Additional Information: 
Generally this refers to procedures where selection is carried out to qualify tenderers who are then requested to submit the rest of their tender for evaluation is Restricted procedure.
WG Approval 15/04/2021"""@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasMinimumNumberOfCandidates ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasNoNegotiationNecessary ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasEstimatedInvitationToExpressInterestDate ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasQualificationSystemDuration ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasSuccessiveReduction ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasEstimatedInvitationToTenderDate ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasMaximumNumberOfCandidates ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasQualificationSystemPeriod ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasQualificationSystemRenewalDescription ],
        epo:LotSpecificTerm ;
    owl:disjointWith epo:AccessTerm,
        epo:DesignContestRegimeTerm,
        epo:EvaluationTerm,
        epo:FrameworkAgreementTerm,
        epo:OpeningTerm,
        epo:ParticipationRequestTerm,
        epo:ReviewTerm,
        epo:SecurityClearanceTerm,
        epo:SubmissionTerm ;
    skos:definition """Conditions and stipulations defining particularities of procedures carried out in several steps
Additional Information: 
Generally this refers to procedures where selection is carried out to qualify tenderers who are then requested to submit the rest of their tender for evaluation is Restricted procedure.
WG Approval 15/04/2021"""@en ;
    skos:prefLabel "Multiple stage procedure term"@en .

epo:ProcurementServiceProvider a owl:Class ;
    rdfs:label "Procurement service provider"@en ;
    rdfs:comment """Role of a public or private body which offers ancillary purchasing activities on the market.

Additional information

"Ancillary purchasing activities" means activities consisting in the provision of support to purchasing activities, in particular in the following forms:
(a) technical infrastructure enabling contracting authorities to award public contracts or to conclude framework agreements for works, supplies or services;
(b) advice on the conduct or design of public procurement procedures;
(c) preparation and management of procurement procedures on behalf and for the account of the contracting authority concerned;

Source: Directive 2014/24/EU, Article 2, paragraphs 17 and 15.

This would be equivalent to the concept of 'procuringEntity' in OCDS: 'The entity managing the procurement, which may be different from the buyer who is paying / using the items being procured'.

WG Approval 24/03/2020
"""@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty epo:actsOnBehalfOf ],
        epo:AcquiringParty ;
    owl:disjointWith epo:Awarder,
        epo:BudgetProvider,
        epo:Buyer,
        epo:CatalogueReceiver,
        epo:Mediator,
        epo:OfflineAccessProvider,
        epo:ParticipationRequestProcessor,
        epo:ParticipationRequestReceiver,
        epo:PaymentExecutor,
        epo:ProcurementProcedureInformationProvider,
        epo:ReviewProcedureInformationProvider,
        epo:Reviewer,
        epo:TenderProcessor,
        epo:TenderReceiver ;
    skos:definition """Role of a public or private body which offers ancillary purchasing activities on the market.

Additional information

"Ancillary purchasing activities" means activities consisting in the provision of support to purchasing activities, in particular in the following forms:
(a) technical infrastructure enabling contracting authorities to award public contracts or to conclude framework agreements for works, supplies or services;
(b) advice on the conduct or design of public procurement procedures;
(c) preparation and management of procurement procedures on behalf and for the account of the contracting authority concerned;

Source: Directive 2014/24/EU, Article 2, paragraphs 17 and 15.

This would be equivalent to the concept of 'procuringEntity' in OCDS: 'The entity managing the procurement, which may be different from the buyer who is paying / using the items being procured'.

WG Approval 24/03/2020
"""@en ;
    skos:prefLabel "Procurement service provider"@en .

epo:Tender a owl:Class ;
    rdfs:label "Tender"@en ;
    rdfs:comment """Information submitted by the economic operator to specify its offer regarding a specific lot, in response to the call for tender.

(WG approval 03/05/2022)


"""@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:foreseesConcession ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:isSubmitedBy ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty epo:isSubmittedForLot ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasElectronicSubmission ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:isSubjectToGrouping ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasFinancialOfferValue ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:isVariant ],
        epo:ProcurementElement ;
    owl:disjointWith epo:AwardDecision,
        epo:Contract,
        epo:ProcurementObject,
        epo:ReviewObject ;
    skos:definition """Information submitted by the economic operator to specify its offer regarding a specific lot, in response to the call for tender.

(WG approval 03/05/2022)


"""@en ;
    skos:prefLabel "Tender"@en .

org:Organization a owl:Class ;
    rdfs:label "Organization"@en ;
    rdfs:comment """A collection of people organized together into a community or other social, commercial or political structure. The group has some common purpose or reason for existence which goes beyond the set of people belonging to it and can act as an Agent. Organisations are often decomposable into hierarchical structures.

(WG approval 23/11/2018).
"""@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasLegalFormType ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasMainActivityDescription ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasLegalName ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:registeredAddress ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasDeliveryGateway ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasBuyerLegalTypeDescription ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasOrganisationUnit ],
        foaf:Agent ;
    owl:disjointWith epo:System,
        foaf:Person ;
    skos:definition """A collection of people organized together into a community or other social, commercial or political structure. The group has some common purpose or reason for existence which goes beyond the set of people belonging to it and can act as an Agent. Organisations are often decomposable into hierarchical structures.

(WG approval 23/11/2018).
"""@en ;
    skos:prefLabel "Organization"@en .

epo:Lot a owl:Class ;
    rdfs:label "Lot"@en ;
    rdfs:comment """A qualitative, quantitative or strategic subdivision of the goods, services or works to be procured, allowing the award of one or more contracts.

WG approval 12/09/2018"""@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasRestatedEstimatedValue ],
        epo:ProcurementObject ;
    owl:disjointWith epo:PlannedProcurementPart,
        epo:Procedure ;
    skos:definition """A qualitative, quantitative or strategic subdivision of the goods, services or works to be procured, allowing the award of one or more contracts.

WG approval 12/09/2018"""@en ;
    skos:prefLabel "Lot"@en .

epo:Procedure a owl:Class ;
    rdfs:label "Procedure"@en ;
    rdfs:comment """A legally defined set of administrative activities conducted  to conclude one or more contracts.

Additional Information
The procedure is categorised in the law according to different rules determining whether the procedure is open, restricted, negotiated with or without  publicity, etc. (see Procedure Type).

WG Approval 20/08/2019
"""@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:isExecutedByProcurementServiceProvider ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:isAccelerated ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty epo:isSubjectToProcedureSpecificTerm ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:isDesignContest ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty epo:hasProcurementScopeDividedIntoLot ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:isJointProcurement ],
        epo:ProcurementObject ;
    owl:disjointWith epo:Lot,
        epo:PlannedProcurementPart ;
    skos:definition """A legally defined set of administrative activities conducted  to conclude one or more contracts.

Additional Information
The procedure is categorised in the law according to different rules determining whether the procedure is open, restricted, negotiated with or without  publicity, etc. (see Procedure Type).

WG Approval 20/08/2019
"""@en ;
    skos:prefLabel "Procedure"@en .

epo:ProcedureTerm a owl:Class ;
    rdfs:label "Procedure term"@en ;
    rdfs:comment """Conditions and stipulations defining particularities of the procedure.

(WG approval 23/11/2018)"""@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasLotAwardLimit ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:definesMediator ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:isAwardedByCPB ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasMaximumLotSubmissionAllowed ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:definesBudgetProvider ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasMaximumNumberOfLotsToBeAwarded ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:isOneLotOnlyAllowed ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:isSubmissionForAllLotsAllowed ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasLotAwardCombination ],
        epo:ProcedureSpecificTerm ;
    owl:disjointWith epo:AccessTerm,
        epo:DirectAwardTerm,
        epo:FrameworkAgreementTerm,
        epo:ReviewTerm,
        epo:SubmissionTerm ;
    skos:definition """Conditions and stipulations defining particularities of the procedure.

(WG approval 23/11/2018)"""@en ;
    skos:prefLabel "Procedure term"@en .

epo:ProcurementObject rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:isRecurrent ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:isSMESuitable ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasPurpose ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:isCoveredByGPA ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasEstimatedValue ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:isUsingEUFunds ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty epo:hasID ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasRecurrenceDescription ] ;
    owl:disjointWith epo:Contract,
        epo:Tender .

epo:AccessTerm a owl:Class ;
    rdfs:label "Access term"@en ;
    rdfs:comment """Conditions and stipulations about where and how to access the procurement documents.

WG Approval 09/03/2021

"""@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:definesProcurementProcedureInformationProvider ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasPublicAccessURL ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty epo:involvesProcurementDocument ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasAdditionalInformationDeadline ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasRestrictedAccessURL ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:isProcurementDocumentRestricted ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:definesOfflineAccessProvider ],
        epo:LotSpecificTerm,
        epo:ProcedureSpecificTerm ;
    owl:disjointWith epo:DesignContestRegimeTerm,
        epo:DirectAwardTerm,
        epo:EvaluationTerm,
        epo:FrameworkAgreementTerm,
        epo:MultipleStageProcedureTerm,
        epo:OpeningTerm,
        epo:ParticipationRequestTerm,
        epo:ProcedureTerm,
        epo:ReviewTerm,
        epo:SecurityClearanceTerm,
        epo:SubmissionTerm ;
    skos:definition """Conditions and stipulations about where and how to access the procurement documents.

WG Approval 09/03/2021

"""@en ;
    skos:prefLabel "Access term"@en .

epo:LotAwardOutcome a owl:Class ;
    rdfs:label "Lot award outcome"@en ;
    rdfs:comment "Result concerning the Lot attributed by the awarder."@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasAwardDecisionDate ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasAdditionalNonAwardJustification ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:isAdoptedByBuyer ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty epo:describesLot ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasNonAwardedContractNumber ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasNonAwardedContractTitle ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasRestatedAwardedValue ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasBargainPrice ],
        [ a owl:Restriction ;
