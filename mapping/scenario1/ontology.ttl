        epo:ProcurementProcedureInformationProvider,
        epo:ProcurementServiceProvider,
        epo:ReviewProcedureInformationProvider,
        epo:Reviewer,
        epo:TenderProcessor,
        epo:TenderReceiver ;
    skos:definition "A role of an agent whose budget is used to pay for the contract."@en ;
    skos:prefLabel "Budget provider"@en .

