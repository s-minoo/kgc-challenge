    rdfs:label "Has framework agreement estimated value"@en ;
    rdfs:comment "This refers to BT-660 in eForms. (epo:LotAwardOutcome -> epo:MonetaryValue (+epo:hasFrameworkAgreementEstimatedValue)) "@en ;
    rdfs:domain epo:LotAwardOutcome ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range epo:MonetaryValue ;
    skos:definition "This refers to BT-660 in eForms. (epo:LotAwardOutcome -> epo:MonetaryValue (+epo:hasFrameworkAgreementEstimatedValue)) "@en ;
    skos:prefLabel "Has framework agreement estimated value"@en .

epo:hasFrameworkAgreementMaximumValue a owl:ObjectProperty ;
    rdfs:label "Has framework agreement maximum value"@en ;
    rdfs:comment "This refers to BT-709 in eForms. (epo:LotAwardOutcome -> epo:MonetaryValue (+epo:hasFrameworkAgreementMaximumValue)) "@en ;
    rdfs:domain epo:LotAwardOutcome ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range epo:MonetaryValue ;
    skos:definition "This refers to BT-709 in eForms. (epo:LotAwardOutcome -> epo:MonetaryValue (+epo:hasFrameworkAgreementMaximumValue)) "@en ;
    skos:prefLabel "Has framework agreement maximum value"@en .

epo:hasHighestReceivedTenderValue a owl:ObjectProperty ;
    rdfs:label "Has highest received tender value"@en ;
    rdfs:comment """Amount of the Tender with the highest value.

Additional Information
The value must correspond to an admissible tender. For example, tenders compliant with the procurement document requirements, not having an abnormally low price or cost, etc. 


WG Approval 12/12/2019


 (epo:SubmissionStatisticalInformation -> epo:MonetaryValue (+epo:hasHighestReceivedTenderValue)) """@en ;
    rdfs:domain epo:SubmissionStatisticalInformation ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range epo:MonetaryValue ;
    skos:definition """Amount of the Tender with the highest value.

Additional Information
The value must correspond to an admissible tender. For example, tenders compliant with the procurement document requirements, not having an abnormally low price or cost, etc. 


WG Approval 12/12/2019


 (epo:SubmissionStatisticalInformation -> epo:MonetaryValue (+epo:hasHighestReceivedTenderValue)) """@en ;
    skos:prefLabel "Has highest received tender value"@en .

epo:hasIdentifierValue a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "Has identifier value"@en ;
    rdfs:comment "The literal identifying an entity, like a person or an object. (epo:Identifier) "@en ;
