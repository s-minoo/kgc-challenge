epo:ReviewProcedureInformationProvider a owl:Class ;
    rdfs:label "Review procedure information provider"@en ;
    rdfs:comment "A role of an agent who is providing more information on the time limits for review procedures."@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
