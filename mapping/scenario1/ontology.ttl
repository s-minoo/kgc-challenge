    skos:definition "A role of an agent responsible for executing the payment."@en ;
    skos:prefLabel "Payment executor"@en .

epo:ReviewTerm a owl:Class ;
    rdfs:label "Review term"@en ;
    rdfs:comment """Conditions and stipulations defining particularities of the review.

(WG approval 23/11/2018)
"""@en ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
