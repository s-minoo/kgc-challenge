epo:hasAmountValue a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "Has amount value"@en ;
    rdfs:comment "The numeric value of the amount, including decimals. (epo:MonetaryValue) "@en ;
    rdfs:domain epo:MonetaryValue ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range xsd:decimal ;
    skos:definition "The numeric value of the amount, including decimals. (epo:MonetaryValue) "@en ;
    skos:prefLabel "Has amount value"@en .

epo:hasAwardCriteriaOrderJustification rdfs:domain epo:AwardEvaluationTerm .

epo:hasAwardDateScheduled rdfs:domain epo:ProcessPlanningTerm ;
    rdfs:range xsd:date .

epo:hasAwardDecisionDate a owl:DatatypeProperty ;
    rdfs:label "Has award decision date"@en ;
    rdfs:comment """The official date of the award decision.

Additional Information:
This corresponds in eForms to BT-1451 Winner Decision Date.

WG Approval 09/01/2020
 (epo:LotAwardOutcome) """@en ;
    rdfs:domain epo:LotAwardOutcome ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range xsd:date ;
    skos:definition """The official date of the award decision.

Additional Information:
This corresponds in eForms to BT-1451 Winner Decision Date.

WG Approval 09/01/2020
 (epo:LotAwardOutcome) """@en ;
    skos:prefLabel "Has award decision date"@en .

epo:hasAwardRank a owl:DatatypeProperty ;
    rdfs:label "Has award rank"@en ;
    rdfs:comment """The position of the tender (i.e. whether the tender ended up first, second, third, etc.) in a design contest, some framework agreements with multiple winners (e.g. cascades) or an innovation partnership.

Additional Information:
This corresponds in eForms to BT-171 Tender Rank.
 (epo:TenderAwardOutcome) """@en ;
    rdfs:domain epo:TenderAwardOutcome ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range xsd:integer ;
    skos:definition """The position of the tender (i.e. whether the tender ended up first, second, third, etc.) in a design contest, some framework agreements with multiple winners (e.g. cascades) or an innovation partnership.

Additional Information:
This corresponds in eForms to BT-171 Tender Rank.
 (epo:TenderAwardOutcome) """@en ;
    skos:prefLabel "Has award rank"@en .

epo:hasAwardedEstimatedValue rdfs:domain epo:LotAwardOutcome ;
    rdfs:range epo:MonetaryValue .

epo:hasAwardedValue a owl:ObjectProperty ;
    rdfs:label "Has awarded value"@en ;
    rdfs:comment """The value of the procurement provided by the Award Decision.

Additional Information:
Different cases of awarded values may refer to a lot, the global value of the procedure, or of a combinatorial value of a group of lots.

In the case of framework agreements and dynamic purchasing systems this refers to the maximum awarded value.

WG Approval 10/12/2019 (epo:LotAwardOutcome -> epo:MonetaryValue (+epo:hasAwardedValue)) """@en ;
    rdfs:domain epo:LotAwardOutcome ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range epo:MonetaryValue ;
    skos:definition """The value of the procurement provided by the Award Decision.

Additional Information:
Different cases of awarded values may refer to a lot, the global value of the procedure, or of a combinatorial value of a group of lots.

In the case of framework agreements and dynamic purchasing systems this refers to the maximum awarded value.

WG Approval 10/12/2019 (epo:LotAwardOutcome -> epo:MonetaryValue (+epo:hasAwardedValue)) """@en ;
    skos:prefLabel "Has awarded value"@en .

epo:hasBargainPrice rdfs:domain epo:LotAwardOutcome ;
    rdfs:range epo:MonetaryValue .

epo:hasBeginning a owl:DatatypeProperty ;
    rdfs:label "Has beginning"@en ;
    rdfs:comment "The date and time on which this period begins. (epo:Period) "@en ;
    rdfs:domain epo:Period ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range xsd:dateTime ;
    skos:definition "The date and time on which this period begins. (epo:Period) "@en ;
    skos:prefLabel "Has beginning"@en .

epo:hasBuyerLegalTypeDescription a owl:DatatypeProperty ;
    rdfs:label "Has buyer legal type description"@en ;
    rdfs:comment """Self-explanatory text about the Buyer Legal Type.

Additional information:
This field is used when the Buyer Legal Type is not available in the controlled list at-voc:buyer-legal-type . This is necessary in to cover data provided in the TED Standard Forms. It shall be deprecated in the future. 

WG Approval 06/09/2022 (org:Organization) """@en ;
    rdfs:domain org:Organization ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range rdfs:Literal ;
    skos:definition """Self-explanatory text about the Buyer Legal Type.

Additional information:
This field is used when the Buyer Legal Type is not available in the controlled list at-voc:buyer-legal-type . This is necessary in to cover data provided in the TED Standard Forms. It shall be deprecated in the future. 

WG Approval 06/09/2022 (org:Organization) """@en ;
    skos:prefLabel "Has buyer legal type description"@en .

epo:hasBuyerProfile a owl:DatatypeProperty ;
    rdfs:label "Has buyer profile"@en ;
    rdfs:comment """Website address where the buyer publishes information on its procurement procedures and general information.

Additional information:
This corresponds in the eForms to BT-508 Buyer Profile URL.

WG approval 04/05/2018
 (epo:Buyer) """@en ;
    rdfs:domain epo:Buyer ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range xsd:anyURI ;
    skos:definition """Website address where the buyer publishes information on its procurement procedures and general information.

Additional information:
This corresponds in the eForms to BT-508 Buyer Profile URL.

WG approval 04/05/2018
 (epo:Buyer) """@en ;
    skos:prefLabel "Has buyer profile"@en .

epo:hasCleanVehicles a owl:DatatypeProperty ;
    rdfs:label "Has clean vehicles"@en ;
    rdfs:comment """The number of all clean vehicles that have either been purchased, leased, rented, hired-purchased or their use has been contractually committed to for the provision of a purchased service.

Additional Information
In the European Union, the legal requirements and scope for the provision of these vehicles or services are covered by Directive 2009/33/EC.

WG Approval 28/07/2020
 (epo:GreenProcurement) """@en ;
    rdfs:domain epo:GreenProcurement ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range xsd:integer ;
    skos:definition """The number of all clean vehicles that have either been purchased, leased, rented, hired-purchased or their use has been contractually committed to for the provision of a purchased service.

Additional Information
In the European Union, the legal requirements and scope for the provision of these vehicles or services are covered by Directive 2009/33/EC.

WG Approval 28/07/2020
 (epo:GreenProcurement) """@en ;
    skos:prefLabel "Has clean vehicles"@en .

epo:hasContactName a owl:DatatypeProperty ;
    rdfs:label "Has contact name"@en ;
    rdfs:comment """A short text by which a contact is known or referred to.

WG Approval: 27/01/2022 (cpov:ContactPoint) """@en ;
    rdfs:domain <http://data.europa.eu/m8g/ContactPoint> ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range rdfs:Literal ;
    skos:definition """A short text by which a contact is known or referred to.

WG Approval: 27/01/2022 (cpov:ContactPoint) """@en ;
    skos:prefLabel "Has contact name"@en .

epo:hasContractConclusionDate a owl:DatatypeProperty ;
    rdfs:label "Has contract conclusion date"@en ;
    rdfs:comment """The date the contract was signed by the last signatory party.

<u>Additional Information:</u>
In exceptional cases contracts may be concluded without signature and therefore another date may be used. The date of contract conclusion is always later than the end of any standstill period.
This concept is not to be confused with the date of completion/end of the contract.

This corresponds in eForms to BT-145         Contract Conclusion Date.

WG Approval 09/01/2020 (epo:Contract) """@en ;
    rdfs:domain epo:Contract ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range xsd:date ;
    skos:definition """The date the contract was signed by the last signatory party.

<u>Additional Information:</u>
In exceptional cases contracts may be concluded without signature and therefore another date may be used. The date of contract conclusion is always later than the end of any standstill period.
This concept is not to be confused with the date of completion/end of the contract.

This corresponds in eForms to BT-145         Contract Conclusion Date.

WG Approval 09/01/2020 (epo:Contract) """@en ;
    skos:prefLabel "Has contract conclusion date"@en .

epo:hasContractorLegalFormRequirement a owl:DatatypeProperty ;
    rdfs:label "Has contractor legal form requirement"@en ;
    rdfs:comment """A specific legal entity must be taken up by a tenderer composed of a group of economic operators once it has been awarded a contract.

Additional information: this may be applied in the case of groups (e.g. a consortium) where the requirement is that they have to formalise the relationship of the group members as a legal entity itself once the contract is awarded.

WG Approval 2019-01-29
 (epo:ContractTerm) """@en ;
    rdfs:domain epo:ContractTerm ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range xsd:boolean ;
    skos:definition """A specific legal entity must be taken up by a tenderer composed of a group of economic operators once it has been awarded a contract.

Additional information: this may be applied in the case of groups (e.g. a consortium) where the requirement is that they have to formalise the relationship of the group members as a legal entity itself once the contract is awarded.

WG Approval 2019-01-29
 (epo:ContractTerm) """@en ;
    skos:prefLabel "Has contractor legal form requirement"@en .

epo:hasDeliveryGateway a owl:ObjectProperty ;
    rdfs:label "Has delivery gateway"@en ;
    rdfs:domain org:Organization ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range <http://data.europa.eu/m8g/Channel> ;
    skos:prefLabel "Has delivery gateway"@en .

epo:hasDescription a owl:DatatypeProperty ;
    rdfs:label "Has description"@en ;
    rdfs:comment """Explanatory text about the instance of the concept.

WG Approval 30/09/2019
 (cccev:InformationConcept) Explanatory text about the instance of the concept.

WG Approval 30/09/2019 (cpov:ContactPoint) Explanatory text about the instance of the concept.

WG Approval 30/09/2019 (cv:Channel) Explanatory text about the instance of the concept.

WG Approval 30/09/2019 (epo:AgentInRole) Explanatory text about the instance of the concept.

WG Approval 30/09/2019 (epo:Fund) Explanatory text about the instance of the concept.

WG Approval 30/09/2019
 (epo:SecurityClearanceTerm) Explanatory text about the instance of the concept.

WG Approval 30/09/2019
 (epo:SubcontractingEstimate) Explanatory text about the instance of the concept.

WG Approval 30/09/2019 (epo:SubcontractTerm) Explanatory text about the instance of the concept.

WG Approval 30/09/2019 (epo:System) Explanatory text about the instance of the concept.

WG Approval 30/09/2019 (epo:TechniqueUsage) Explanatory text about the instance of the concept.

WG Approval 30/09/2019
 (epo:ProcurementElement) Explanatory text about the instance of the concept.

WG Approval 30/09/2019 (epo:Period) """@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( <http://data.europa.eu/m8g/InformationConcept> <http://data.europa.eu/m8g/ContactPoint> <http://data.europa.eu/m8g/Channel> epo:AgentInRole epo:Fund epo:SecurityClearanceTerm epo:SubcontractingEstimate epo:SubcontractTerm epo:System epo:TechniqueUsage epo:ProcurementElement epo:Period ) ] ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range rdfs:Literal ;
    skos:definition """Explanatory text about the instance of the concept.

WG Approval 30/09/2019
 (cccev:InformationConcept) Explanatory text about the instance of the concept.

WG Approval 30/09/2019 (cpov:ContactPoint) Explanatory text about the instance of the concept.

WG Approval 30/09/2019 (cv:Channel) Explanatory text about the instance of the concept.

WG Approval 30/09/2019 (epo:AgentInRole) Explanatory text about the instance of the concept.

WG Approval 30/09/2019 (epo:Fund) Explanatory text about the instance of the concept.

WG Approval 30/09/2019
 (epo:SecurityClearanceTerm) Explanatory text about the instance of the concept.

WG Approval 30/09/2019
 (epo:SubcontractingEstimate) Explanatory text about the instance of the concept.

WG Approval 30/09/2019 (epo:SubcontractTerm) Explanatory text about the instance of the concept.

WG Approval 30/09/2019 (epo:System) Explanatory text about the instance of the concept.

WG Approval 30/09/2019 (epo:TechniqueUsage) Explanatory text about the instance of the concept.

WG Approval 30/09/2019
 (epo:ProcurementElement) Explanatory text about the instance of the concept.

WG Approval 30/09/2019 (epo:Period) """@en ;
    skos:prefLabel "Has description"@en .

