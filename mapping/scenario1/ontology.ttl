    rdfs:range xsd:anyURI .

epo:hasSuccessiveReduction a owl:DatatypeProperty ;
    rdfs:label "Has successive reduction"@en ;
    rdfs:comment """The number of solutions or tenders will be reduced in iterative evaluations for multiple staged procedures.

Additional information:
This refers to multiple-stage procedures (included two-stage procedures, at least). Open Procedures can be seen as one-stage procedures.
WG Approval 22/08/2019  (epo:MultipleStageProcedureTerm) """@en ;
    rdfs:domain epo:MultipleStageProcedureTerm ;
