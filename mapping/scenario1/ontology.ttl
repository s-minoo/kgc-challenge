epo:isFundedBy a owl:ObjectProperty ;
    rdfs:label "Is funded by"@en ;
    rdfs:comment """Additional information:
This corresponds in eForms to BG - 61 EU Funds (specified per Lot) and to BG - 611 Contract EU Funds (applied per Contract lot)
Funds may change between the lot and the contract, for example in the case of an emergency crisis, a contract may be financed by a budget that was not foreseen in the call.

 (epo:ProcurementObject -> epo:Fund (+epo:isFundedBy)) """@en ;
    rdfs:domain epo:ProcurementObject ;
    rdfs:isDefinedBy <http://data.europa.eu/a4g/ontology> ;
    rdfs:range epo:Fund ;
